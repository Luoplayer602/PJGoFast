@model TripSummaryVM
@using System.Text.Json

@{
    ViewData["Title"] = "Tiến trình chuyến";
    var userAgent = Context.Request.Headers["User-Agent"].ToString().ToLower();
    var isMobile = userAgent.Contains("mobi") || userAgent.Contains("android") || userAgent.Contains("iphone");
    Layout = isMobile ? "_LayoutTaiXeMobile" : "_LayoutTaiXe";
}

<style>
    .progress-page {
        display: grid;
        grid-template-columns: minmax(0, 1.45fr) minmax(320px, .9fr);
        gap: 18px;
    }

    .progress-card {
        background: #fff;
        border-radius: 24px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 10px 28px rgba(15,23,42,.06);
        overflow: hidden;
    }

    .progress-hero {
        background: linear-gradient(160deg, #0f172a, #1d4ed8 72%, #3b82f6);
        color: #fff;
        padding: 24px;
    }

    .progress-hero h1 {
        margin: 0 0 8px;
        font-size: 1.55rem;
        font-weight: 800;
    }

    .hero-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 16px;
    }

    .hero-chip {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 12px;
        border-radius: 999px;
        background: rgba(255,255,255,.14);
        border: 1px solid rgba(255,255,255,.18);
        font-size: .8rem;
        font-weight: 700;
    }

    .timeline-wrap {
        padding: 24px;
    }

    .timeline {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 12px;
        align-items: center;
    }

    .timeline-item {
        position: relative;
        text-align: center;
    }

    .timeline-item::after {
        content: "";
        position: absolute;
        top: 24px;
        right: calc(-50% - 6px);
        width: calc(100% + 12px);
        height: 2px;
        background: #dbe4f0;
        z-index: 0;
    }

    .timeline-item:last-child::after {
        display: none;
    }

    .timeline-dot {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        margin: 0 auto 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #eff6ff;
        color: #1d4ed8;
        position: relative;
        z-index: 1;
        box-shadow: 0 0 0 6px #fff;
    }

    .timeline-item.done .timeline-dot {
        background: #dcfce7;
        color: #15803d;
    }

    .timeline-item.current .timeline-dot {
        background: #ffedd5;
        color: #c2410c;
    }

    .timeline-item label {
        display: block;
        font-size: .8rem;
        font-weight: 800;
        color: #334155;
    }

    .timeline-item button {
        margin-top: 10px;
        width: 100%;
        border: none;
        border-radius: 14px;
        padding: 11px 10px;
        font-weight: 800;
        font-size: .82rem;
        background: #eff6ff;
        color: #1d4ed8;
    }

    .timeline-item button:disabled {
        background: #f8fafc;
        color: #94a3b8;
        cursor: not-allowed;
    }

    .progress-grid {
        padding: 0 24px 24px;
        display: grid;
        gap: 18px;
    }

    .info-block {
        background: #f8fbff;
        border: 1px solid #e2e8f0;
        border-radius: 20px;
        padding: 18px;
    }

    .info-block h2 {
        margin: 0 0 12px;
        font-size: .84rem;
        text-transform: uppercase;
        letter-spacing: .06em;
        color: #64748b;
        font-weight: 800;
    }

    .info-item + .info-item {
        margin-top: 10px;
    }

    .info-item small {
        display: block;
        color: #94a3b8;
        margin-bottom: 3px;
    }

    .info-item strong {
        display: block;
        line-height: 1.45;
        color: #0f172a;
    }

    .action-stack {
        display: grid;
        gap: 10px;
    }

    .action-stack .btn {
        border-radius: 16px;
        padding: 12px 16px;
        font-weight: 800;
    }

    .log-list {
        display: grid;
        gap: 10px;
    }

    .log-item {
        padding: 12px 14px;
        border-radius: 16px;
        border: 1px solid #e2e8f0;
        background: #fff;
    }

    .log-item small {
        display: block;
        margin-top: 4px;
        color: #94a3b8;
    }

    @@media (max-width: 992px) {
        .progress-page {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 768px) {
        .timeline {
            grid-template-columns: 1fr;
        }

        .timeline-item::after {
            top: auto;
            right: auto;
            left: 50%;
            bottom: -12px;
            width: 2px;
            height: 24px;
            transform: translateX(-50%);
        }
    }
</style>

<div class="progress-page">
    <section class="progress-card">
        <div class="progress-hero">
            <h1>Tiến trình chuyến @Model.IdChuyenDi</h1>
            <div>Khách hàng: <strong>@Model.KhachHang?.HoVaTen</strong> · @Model.KhachHang?.SDT</div>
            <div class="hero-meta">
                <span class="hero-chip" id="statusChip"><i class="bi bi-flag"></i>@Model.TrangThai</span>
                <span class="hero-chip"><i class="bi bi-clock"></i>@Model.ThoiGianDon.ToString("HH:mm dd/MM/yyyy")</span>
                <span class="hero-chip"><i class="bi bi-cash-stack"></i>@(Model.GiaTamTinh?.ToString("N0") ?? "0") đ</span>
            </div>
        </div>

        <div class="timeline-wrap">
            <div class="timeline" id="timelineRoot"></div>
        </div>

        <div class="progress-grid">
            <div class="info-block">
                <h2>Lộ trình</h2>
                <div class="info-item">
                    <small>Điểm đón</small>
                    <strong>@Model.DiemDon</strong>
                </div>
                <div class="info-item">
                    <small>Điểm đến</small>
                    <strong>@Model.DiemDen</strong>
                </div>
                <div class="info-item">
                    <small>Ghi chú</small>
                    <strong>@(string.IsNullOrWhiteSpace(Model.GhiChu) ? "Không có" : Model.GhiChu)</strong>
                </div>
            </div>

            <div class="info-block">
                <h2>Nhật ký cập nhật</h2>
                <div class="log-list" id="logList"></div>
            </div>
        </div>
    </section>

    <section class="progress-card">
        <div class="progress-grid pt-4">
            <div class="info-block">
                <h2>Thao tác riêng</h2>
                <div class="action-stack">
                    <button type="button" class="btn btn-outline-danger" onclick="showModal('Hủy chuyến', 'Bạn sẽ chuyển chuyến đi về trạng thái hủy.', 'cancelForm')">
                        <i class="bi bi-x-circle me-1"></i> Hủy chuyến
                    </button>
                    <button type="button" class="btn btn-warning text-white" id="paymentButton" onclick="paymentModal.show()" disabled>
                        <i class="bi bi-credit-card me-1"></i> Xác nhận thanh toán
                    </button>
                    <a asp-action="Index" class="btn btn-light border">
                        <i class="bi bi-arrow-left me-1"></i> Quay lại danh sách
                    </a>
                </div>
            </div>

            <div class="info-block">
                <h2>Thông tin liên hệ</h2>
                <div class="info-item">
                    <small>Khách hàng</small>
                    <strong>@Model.KhachHang?.HoVaTen · @Model.KhachHang?.SDT</strong>
                </div>
                <div class="info-item">
                    <small>Điều phối</small>
                    <strong>@(Model.Admin?.HoVaTen ?? "Chưa có")</strong>
                </div>
                <div class="info-item">
                    <small>Thanh toán</small>
                    <strong id="paymentStatus">@(Model.HasPayment ? $"{Model.PhuongThucThanhToan} · {Model.SoTienThanhToan:N0} đ" : "Chưa xác nhận")</strong>
                </div>
            </div>
        </div>
    </section>
</div>

<form id="statusForm" asp-action="CapNhatTienTrinh" method="post" class="d-none">
    @Html.AntiForgeryToken()
    <input type="hidden" name="idChuyenDi" value="@Model.IdChuyenDi" />
    <input type="hidden" name="trangThaiMoi" id="statusTarget" value="" />
</form>

<form id="cancelForm" asp-action="HuyChuyen" method="post" class="d-none">
    @Html.AntiForgeryToken()
    <input type="hidden" name="idChuyenDi" value="@Model.IdChuyenDi" />
</form>

<div class="modal fade" id="confirmStatusModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4">
            <div class="modal-body p-4">
                <h5 class="fw-bold mb-2" id="statusModalTitle"></h5>
                <p class="text-muted mb-4" id="statusModalText"></p>
                <div class="d-grid gap-2">
                    <button type="button" class="btn btn-primary btn-lg rounded-4" id="statusModalConfirm">Xác nhận</button>
                    <button type="button" class="btn btn-light btn-lg rounded-4" data-bs-dismiss="modal">Đóng</button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="paymentModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4">
            <form asp-action="XacNhanThanhToan" method="post" class="modal-body p-4">
                @Html.AntiForgeryToken()
                <input type="hidden" name="IdChuyenDi" value="@Model.IdChuyenDi" />
                <h5 class="fw-bold mb-3">Xác nhận thanh toán</h5>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Phương thức</label>
                    <select class="form-select form-select-lg rounded-4" name="PhuongThucThanhToan">
                        <option value="TienMat">Tiền mặt</option>
                        <option value="ChuyenKhoan">Chuyển khoản</option>
                        <option value="The">Thẻ</option>
                    </select>
                </div>
                <div class="mb-4">
                    <label class="form-label fw-semibold">Số tiền thu hộ</label>
                    <input class="form-control form-control-lg rounded-4" type="number" min="0" name="SoTienThanhToan" value="@(Model.GiaThucTe ?? Model.GiaTamTinh ?? 0)" />
                </div>
                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-warning text-white btn-lg rounded-4">Ghi nhận thanh toán</button>
                    <button type="button" class="btn btn-light btn-lg rounded-4" data-bs-dismiss="modal">Đóng</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const tripId = '@Model.IdChuyenDi';
    let tripData = @Html.Raw(JsonSerializer.Serialize(Model, new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase }));
    const statusModal = new bootstrap.Modal(document.getElementById('confirmStatusModal'));
    const paymentModal = new bootstrap.Modal(document.getElementById('paymentModal'));
    let targetForm = '';

    const steps = [
        { status: 'DANG_DON', label: 'Đang đón', icon: 'bi-car-front-fill' },
        { status: 'DA_DON', label: 'Đã đón', icon: 'bi-person-check-fill' },
        { status: 'DANG_DI_CHUYEN', label: 'Đang di chuyển', icon: 'bi-signpost-split-fill' },
        { status: 'HOAN_TAT', label: 'Hoàn tất', icon: 'bi-check-circle-fill' }
    ];

    const order = ['DA_NHAN', 'DANG_DON', 'DA_DON', 'DANG_DI_CHUYEN', 'HOAN_TAT'];

    function currentIndex() {
        return order.indexOf(tripData.trangThai);
    }

    function renderTimeline() {
        const root = document.getElementById('timelineRoot');
        const idx = currentIndex();
        root.innerHTML = steps.map((step, index) => {
            const stepIndex = order.indexOf(step.status);
            const done = idx > stepIndex;
            const current = tripData.trangThai === step.status;
            const enabled = idx + 1 === stepIndex;
            return `
                <div class="timeline-item ${done ? 'done' : ''} ${current ? 'current' : ''}">
                    <div class="timeline-dot"><i class="bi ${step.icon}"></i></div>
                    <label>${step.label}</label>
                    <button type="button" ${enabled ? '' : 'disabled'} onclick="showModal('${step.label}', 'Bạn xác nhận chuyển chuyến sang trạng thái ${step.label.toLowerCase()}.', 'statusForm', '${step.status}')">
                        Cập nhật
                    </button>
                </div>`;
        }).join('');

        document.getElementById('statusChip').innerHTML = `<i class="bi bi-flag"></i>${tripData.trangThai}`;
        document.getElementById('paymentButton').disabled = !(tripData.trangThai === 'HOAN_TAT' && !tripData.hasPayment);
        document.getElementById('paymentStatus').textContent = tripData.hasPayment
            ? `${tripData.phuongThucThanhToan} · ${Number(tripData.soTienThanhToan || 0).toLocaleString('vi-VN')} đ`
            : 'Chưa xác nhận';
    }

    function renderLogs() {
        document.getElementById('logList').innerHTML = (tripData.logs || []).length
            ? tripData.logs.map(log => `<div class="log-item">${log.logText}<small>${new Date(log.thoiGian).toLocaleString('vi-VN')}</small></div>`).join('')
            : '<div class="log-item">Chưa có nhật ký.</div>';
    }

    function showModal(title, text, formId, status = '') {
        targetForm = formId;
        document.getElementById('statusModalTitle').textContent = title;
        document.getElementById('statusModalText').textContent = text;
        document.getElementById('statusTarget').value = status;
        statusModal.show();
    }

    document.getElementById('statusModalConfirm').addEventListener('click', () => {
        document.getElementById(targetForm)?.submit();
    });

    async function refreshTrip() {
        try {
            const response = await fetch(`@Url.Action("TienTrinhData", "TaiXe")?idChuyenDi=${tripId}`, { cache: 'no-store' });
            const payload = await response.json();
            if (!payload.success || !payload.data) return;
            tripData = payload.data;
            renderTimeline();
            renderLogs();
        } catch {
        }
    }

    renderTimeline();
    renderLogs();
    setInterval(refreshTrip, 7000);
</script>
}
