@model TaiXeAccountVM

@{
    ViewData["Title"] = "Tài khoản tài xế";
    var userAgent = Context.Request.Headers["User-Agent"].ToString().ToLower();
    var isMobile = userAgent.Contains("mobi") || userAgent.Contains("android") || userAgent.Contains("iphone");
    Layout = isMobile ? "_LayoutTaiXeMobile" : "_LayoutTaiXe";
}

<style>
    .driver-account {
        display: grid;
        grid-template-columns: minmax(0, 1.2fr) minmax(280px, .8fr);
        gap: 18px;
    }

    .account-card {
        background: #fff;
        border-radius: 24px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 10px 28px rgba(15,23,42,.06);
        overflow: hidden;
    }

    .account-hero {
        padding: 28px 26px;
        background: linear-gradient(160deg, #0f172a, #1d4ed8 72%, #3b82f6);
        color: #fff;
    }

    .account-hero h1 {
        margin: 0 0 6px;
        font-size: 1.6rem;
        font-weight: 800;
    }

    .hero-chip {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 12px;
        border-radius: 999px;
        background: rgba(255,255,255,.14);
        border: 1px solid rgba(255,255,255,.18);
        font-size: .8rem;
        font-weight: 700;
        margin: 12px 8px 0 0;
    }

    .account-body {
        padding: 22px 24px;
        display: grid;
        gap: 18px;
    }

    .info-block {
        background: #f8fbff;
        border-radius: 20px;
        border: 1px solid #e2e8f0;
        padding: 18px;
    }

    .info-block h2 {
        margin: 0 0 12px;
        font-size: .84rem;
        text-transform: uppercase;
        letter-spacing: .06em;
        color: #64748b;
        font-weight: 800;
    }

    .info-item + .info-item {
        margin-top: 10px;
    }

    .info-item small {
        display: block;
        color: #94a3b8;
        margin-bottom: 3px;
    }

    .info-item strong {
        display: block;
        color: #0f172a;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 12px;
    }

    .stat-card {
        padding: 18px 14px;
        border-radius: 20px;
        background: #fff;
        border: 1px solid #e2e8f0;
        text-align: center;
    }

    .stat-card strong {
        display: block;
        font-size: 1.5rem;
        margin-bottom: 4px;
    }

    @@media (max-width: 992px) {
        .driver-account {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 576px) {
        .stats-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="driver-account">
    <section class="account-card">
        <div class="account-hero">
            <h1>@Model.HoVaTen</h1>
            <div>Tài khoản tài xế đang hoạt động trên hệ thống.</div>
            <div>
                <span class="hero-chip"><i class="bi bi-person-badge"></i>@Model.IdTX</span>
                <span class="hero-chip"><i class="bi bi-telephone"></i>@Model.SDT</span>
                <span class="hero-chip"><i class="bi bi-car-front"></i>@Model.LoaiXe</span>
            </div>
        </div>
        <div class="account-body">
            <div class="info-block">
                <h2>Thông tin cơ bản</h2>
                <div class="info-item"><small>Ngày sinh</small><strong>@(Model.NgaySinh?.ToString("dd/MM/yyyy") ?? "Chưa cập nhật")</strong></div>
                <div class="info-item"><small>Điểm đợi</small><strong>@(string.IsNullOrWhiteSpace(Model.DiemDoi) ? "Chưa cập nhật" : Model.DiemDoi)</strong></div>
                <div class="info-item"><small>Vị trí</small><strong>@(string.IsNullOrWhiteSpace(Model.ViTri) ? "Chưa cập nhật" : Model.ViTri)</strong></div>
                <div class="info-item"><small>Trạng thái hoạt động</small><strong>@Model.TrangThaiHoatDong</strong></div>
                <div class="info-item"><small>Trạng thái online</small><strong>@Model.TrangThaiOnline</strong></div>
            </div>
            <a asp-controller="Login" asp-action="Logout" class="btn btn-outline-danger rounded-4 py-3 fw-bold">
                <i class="bi bi-box-arrow-right me-1"></i> Đăng xuất
            </a>
        </div>
    </section>

    <section class="account-card">
        <div class="account-body">
            <div class="info-block">
                <h2>Thống kê nhanh</h2>
                <div class="stats-grid">
                    <div class="stat-card">
                        <strong>@Model.TongChuyen</strong>
                        <span>Tổng chuyến</span>
                    </div>
                    <div class="stat-card">
                        <strong>@Model.ChuyenHoanTat</strong>
                        <span>Hoàn tất</span>
                    </div>
                    <div class="stat-card">
                        <strong>@Model.ChuyenDangXuLy</strong>
                        <span>Đang xử lý</span>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>
