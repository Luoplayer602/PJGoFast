<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>@ViewData["Title"] - GoFast Tài xế</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        :root {
            --nav-h: 62px;
            --header-h: 58px;
            --tx-primary: #2563eb;
            --tx-bg: #f4f7fb;
            --tx-surface: #ffffff;
            --tx-muted: #94a3b8;
            --safe-bottom: env(safe-area-inset-bottom, 0px);
        }

        html, body {
            min-height: 100%;
            background: var(--tx-bg);
            -webkit-tap-highlight-color: transparent;
        }

        .tx-mobile-header {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            height: var(--header-h);
            background: rgba(255,255,255,.94);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid #e2e8f0;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 14px;
            z-index: 120;
            box-shadow: 0 8px 18px rgba(15,23,42,.05);
        }

        .tx-mobile-brand {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
            color: #0f172a;
            font-weight: 800;
        }

        .tx-mobile-brand img {
            width: 28px;
            height: 28px;
        }

        .tx-mobile-title {
            position: absolute;
            left: 50%;
            transform: translateX(-50%);
            font-size: .98rem;
            font-weight: 800;
            color: #0f172a;
            max-width: 52%;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .tx-mobile-body {
            padding-top: var(--header-h);
            padding-bottom: calc(var(--nav-h) + var(--safe-bottom) + 10px);
        }

        .tx-mobile-toast {
            position: fixed;
            top: calc(var(--header-h) + 8px);
            left: 12px;
            right: 12px;
            z-index: 200;
        }

        .tx-mobile-toast .alert {
            border: none;
            border-radius: 16px;
            box-shadow: 0 10px 22px rgba(15,23,42,.12);
        }

        .tx-bottom-nav {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            height: calc(var(--nav-h) + var(--safe-bottom));
            background: rgba(255,255,255,.98);
            border-top: 1px solid #e2e8f0;
            display: flex;
            padding-bottom: var(--safe-bottom);
            z-index: 120;
            box-shadow: 0 -6px 18px rgba(15,23,42,.06);
        }

        .tx-tab {
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            gap: 3px;
            text-decoration: none;
            color: var(--tx-muted);
            font-size: .7rem;
            font-weight: 700;
        }

        .tx-tab i {
            font-size: 1.35rem;
        }

        .tx-tab.active {
            color: var(--tx-primary);
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    @{
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
        var nhanChuyenActive = currentController == "TaiXe" && (currentAction == "Index" || currentAction == "ChiTietChuyen");
        var tienTrinhActive = currentController == "TaiXe" && currentAction == "TienTrinh";
        var accountActive = currentController == "TaiXe" && currentAction == "Account";
    }
    <header class="tx-mobile-header">
        <a class="tx-mobile-brand" asp-controller="TaiXe" asp-action="Index">
            <img src="~/images/logo.png" alt="GoFast" onerror="this.style.display='none'" />
            GoFast
        </a>
        <span class="tx-mobile-title">@(ViewData["Title"]?.ToString() ?? "GoFast Tài xế")</span>
        <a asp-controller="TaiXe" asp-action="Account" class="text-decoration-none text-dark">
            <i class="bi bi-person-circle fs-4"></i>
        </a>
    </header>

    @if (TempData["Success"] != null || TempData["Error"] != null)
    {
        <div class="tx-mobile-toast">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
        </div>
    }

    <div class="tx-mobile-body">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <nav class="tx-bottom-nav">
        <a asp-controller="TaiXe" asp-action="Index" class="tx-tab @(nhanChuyenActive ? "active" : "")">
            <i class="bi bi-broadcast-pin"></i>
            <span>Nhận chuyến</span>
        </a>
        <a asp-controller="TaiXe" asp-action="Index" class="tx-tab @(tienTrinhActive ? "active" : "")">
            <i class="bi bi-signpost-split"></i>
            <span>Tiến trình</span>
        </a>
        <a asp-controller="TaiXe" asp-action="Account" class="tx-tab @(accountActive ? "active" : "")">
            <i class="bi bi-person-vcard"></i>
            <span>Tài khoản</span>
        </a>
    </nav>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
