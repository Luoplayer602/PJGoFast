<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GoFast Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PJGoFast.styles.css" asp-append-version="true" />
    <style>
        :root {
            --admin-primary: #2563eb;
            --admin-primary-soft: #eff6ff;
            --admin-bg: #f4f6fb;
            --admin-surface: #ffffff;
            --admin-border: #e5e7eb;
            --admin-text: #111827;
            --admin-muted: #6b7280;
        }

        html, body {
            min-height: 100%;
            background: var(--admin-bg);
            color: var(--admin-text);
        }

        body {
            margin: 0;
            font-family: "Segoe UI", system-ui, -apple-system, sans-serif;
        }

        .admin-topbar {
            position: sticky;
            top: 0;
            z-index: 200;
            background: rgba(255, 255, 255, 0.92);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(229, 231, 235, 0.9);
            box-shadow: 0 6px 18px rgba(15, 23, 42, 0.04);
        }

        .admin-topbar-inner {
            max-width: 1180px;
            margin: 0 auto;
            padding: 14px 16px;
            display: flex;
            align-items: center;
            gap: 14px;
            justify-content: space-between;
        }

        .admin-brand {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            color: var(--admin-text);
            text-decoration: none;
            font-weight: 800;
            letter-spacing: -.02em;
        }

        .admin-brand img {
            width: 38px;
            height: 38px;
            object-fit: contain;
            border-radius: 12px;
            background: linear-gradient(135deg, #dbeafe, #eff6ff);
            padding: 5px;
        }

        .admin-brand small {
            display: block;
            font-size: .72rem;
            color: var(--admin-muted);
            font-weight: 700;
            letter-spacing: .08em;
            text-transform: uppercase;
        }

        .admin-nav {
            display: flex;
            align-items: center;
            gap: 8px;
            flex-wrap: wrap;
        }

        .admin-nav-link {
            padding: 9px 14px;
            border-radius: 999px;
            text-decoration: none;
            color: var(--admin-muted);
            font-weight: 700;
            font-size: .92rem;
            transition: all .15s ease;
        }

        .admin-nav-link:hover {
            background: #f8fafc;
            color: var(--admin-text);
        }

        .admin-nav-link.active {
            background: var(--admin-primary-soft);
            color: var(--admin-primary);
        }

        .admin-user {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            background: var(--admin-surface);
            border: 1px solid var(--admin-border);
            border-radius: 999px;
            padding: 6px 12px;
            box-shadow: 0 1px 8px rgba(15, 23, 42, 0.04);
        }

        .admin-user .avatar {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            background: linear-gradient(135deg, #2563eb, #60a5fa);
            color: #fff;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: .95rem;
        }

        .admin-user .meta {
            line-height: 1.1;
        }

        .admin-user .meta strong {
            display: block;
            font-size: .86rem;
        }

        .admin-user .meta span {
            display: block;
            color: var(--admin-muted);
            font-size: .72rem;
        }

        .admin-shell {
            max-width: 1180px;
            margin: 0 auto;
            padding: 24px 16px 40px;
        }

        .admin-alerts {
            margin-bottom: 16px;
        }

        .admin-alerts .alert {
            border: none;
            border-radius: 16px;
            box-shadow: 0 8px 24px rgba(15, 23, 42, 0.08);
        }

        @@media (max-width: 992px) {
            .admin-topbar-inner {
                flex-wrap: wrap;
            }

            .admin-nav {
                order: 3;
                width: 100%;
            }

            .admin-user {
                margin-left: auto;
            }
        }

        @@media (max-width: 576px) {
            .admin-user .meta {
                display: none;
            }

            .admin-shell {
                padding-left: 12px;
                padding-right: 12px;
            }
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    @{
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;
    }
    <header class="admin-topbar">
        <div class="admin-topbar-inner">
            <a class="admin-brand" asp-controller="Admin" asp-action="Index">
                <img src="~/images/logo.png" alt="GoFast" onerror="this.style.display='none'" />
                <span>
                    <small>GoFast</small>
                    Admin Console
                </span>
            </a>

            <nav class="admin-nav">
                <a asp-controller="Admin" asp-action="Index"
                   class="admin-nav-link @(currentAction == "Index" || currentAction == "Details" ? "active" : "")">
                    <i class="bi bi-people-fill me-1"></i> Danh sách admin
                </a>
                <a asp-controller="Admin" asp-action="Create"
                   class="admin-nav-link @(currentAction == "Create" ? "active" : "")">
                    <i class="bi bi-person-plus-fill me-1"></i> Thêm admin
                </a>
            </nav>

            <div class="admin-user">
                <span class="avatar"><i class="bi bi-shield-lock-fill"></i></span>
                <span class="meta">
                    <strong>@(User.Identity?.Name ?? "Quản trị viên")</strong>
                    <span>@(User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "Admin")</span>
                </span>
            </div>
        </div>
    </header>

    <div class="admin-shell">
        @if (TempData["Success"] != null || TempData["Error"] != null)
        {
            <div class="admin-alerts">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
            </div>
        }

        <main role="main">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
