@using PJGoFast.Models.Enums
@using PJGoFast.ViewModels
@model BaoGiaVM

@{
    ViewData["Title"] = "Báo Giá Chuyến Đi";

    // Hiển thị tên loại xe tiếng Việt
    var tenLoaiXe = Model.LoaiXeYeuCau switch
    {
        LoaiXe.XeMay   => "Xe máy",
        LoaiXe.Sedan   => "Xe sedan",
        LoaiXe.SUV     => "Xe SUV",
        LoaiXe.BayCho  => "Xe 7 chỗ",
        LoaiXe.TaiNho  => "Xe tải nhỏ",
        _              => Model.LoaiXeYeuCau.ToString()
    };

    // Icon loại xe
    var iconXe = Model.LoaiXeYeuCau switch
    {
        LoaiXe.XeMay  => "bi-bicycle",
        LoaiXe.TaiNho => "bi-truck",
        _             => "bi-car-front-fill"
    };

    bool coToaDo = Model.DonLat != 0 && Model.DenLat != 0;
}

<style>
    :root {
        --clr-bg:       #f6f7fb;
        --clr-card:     #ffffff;
        --clr-accent:   #2563eb;
        --clr-accent2:  #16a34a;
        --clr-danger:   #dc2626;
        --clr-muted:    #6b7280;
        --clr-border:   #e5e7eb;
        --clr-tag-bg:   #eff6ff;
        --shadow-card:  0 2px 24px rgba(37,99,235,.08), 0 1px 4px rgba(0,0,0,.04);
    }

    body { background: var(--clr-bg); }

    /* ── Receipt card ── */
    .receipt-card {
        background: var(--clr-card);
        border-radius: 20px;
        box-shadow: var(--shadow-card);
        overflow: hidden;
        animation: fadeUp .45s ease both;
    }

    @@keyframes fadeUp {
        from { opacity: 0; transform: translateY(22px); }
        to   { opacity: 1; transform: translateY(0);    }
    }

    /* ── Top banner ── */
    .receipt-banner {
        background: linear-gradient(135deg, #1d4ed8 0%, #2563eb 60%, #3b82f6 100%);
        padding: 28px 32px 24px;
        color: #fff;
    }
    .receipt-banner .check-wrap {
        width: 52px; height: 52px;
        background: rgba(255,255,255,.18);
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-size: 22px;
        flex-shrink: 0;
    }
    .receipt-banner h5 { font-size: 1.15rem; font-weight: 700; margin: 0; }
    .receipt-banner small { opacity: .78; font-size: .8rem; }
    .id-badge {
        background: rgba(255,255,255,.15);
        border-radius: 8px;
        padding: 4px 12px;
        font-size: .75rem;
        font-family: monospace;
        letter-spacing: .05em;
        color: #fff;
        margin-top: 10px;
        display: inline-block;
    }

    /* ── Route row ── */
    .route-row {
        display: flex;
        align-items: stretch;
        gap: 0;
        padding: 24px 28px 0;
    }
    .route-point {
        flex: 1;
        background: var(--clr-bg);
        border-radius: 14px;
        padding: 14px 16px;
        min-width: 0;
    }
    .route-point .label {
        font-size: .72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .07em;
        margin-bottom: 4px;
    }
    .route-point .addr {
        font-size: .9rem;
        font-weight: 600;
        color: #1f2937;
        word-break: break-word;
        line-height: 1.4;
    }
    .route-divider {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 0 10px;
        gap: 3px;
    }
    .route-divider span {
        width: 3px; height: 3px;
        border-radius: 50%;
        background: var(--clr-border);
    }
    .route-divider .arrow-icon {
        font-size: 18px;
        color: var(--clr-accent);
    }

    /* ── Stats row ── */
    .stats-row {
        display: flex;
        gap: 12px;
        padding: 20px 28px 0;
    }
    .stat-chip {
        flex: 1;
        background: var(--clr-bg);
        border-radius: 14px;
        padding: 14px 16px;
        text-align: center;
    }
    .stat-chip .stat-val {
        font-size: 1.35rem;
        font-weight: 800;
        color: #111827;
        line-height: 1.1;
    }
    .stat-chip .stat-unit {
        font-size: .72rem;
        color: var(--clr-muted);
        margin-top: 2px;
    }
    .stat-chip .stat-icon {
        font-size: 1.1rem;
        margin-bottom: 6px;
    }

    /* ── Details list ── */
    .detail-list {
        padding: 20px 28px 0;
    }
    .detail-row {
        display: flex;
        align-items: flex-start;
        padding: 10px 0;
        border-bottom: 1px solid var(--clr-border);
        gap: 10px;
        font-size: .875rem;
    }
    .detail-row:last-child { border-bottom: none; }
    .detail-row .d-key {
        color: var(--clr-muted);
        min-width: 130px;
        display: flex;
        align-items: center;
        gap: 6px;
    }
    .detail-row .d-val { color: #111827; font-weight: 600; }

    /* ── Price box ── */
    .price-box {
        margin: 20px 28px 0;
        background: linear-gradient(135deg, #eff6ff 0%, #f0fdf4 100%);
        border: 1.5px solid #bfdbfe;
        border-radius: 16px;
        padding: 20px 22px;
    }
    .price-box .price-row {
        display: flex;
        justify-content: space-between;
        font-size: .875rem;
        padding: 4px 0;
        color: #374151;
    }
    .price-box .price-row.total {
        border-top: 1.5px dashed #93c5fd;
        margin-top: 10px;
        padding-top: 12px;
        font-size: 1.2rem;
        font-weight: 800;
        color: #1d4ed8;
    }
    .badge-min {
        background: #fef3c7;
        color: #92400e;
        border-radius: 20px;
        padding: 2px 10px;
        font-size: .72rem;
        font-weight: 600;
    }

    /* ── Buttons ── */
    .action-bar {
        padding: 22px 28px 28px;
        display: flex;
        gap: 12px;
    }
    .btn-receipt-map {
        flex: 1;
        padding: 12px 0;
        border-radius: 12px;
        font-weight: 700;
        font-size: .9rem;
        background: var(--clr-accent);
        color: #fff;
        border: none;
        display: flex; align-items: center; justify-content: center; gap: 8px;
        text-decoration: none;
        transition: filter .15s, transform .1s;
    }
    .btn-receipt-map:hover { filter: brightness(1.08); color: #fff; transform: translateY(-1px); }
    .btn-receipt-back {
        flex: 0 0 auto;
        padding: 12px 20px;
        border-radius: 12px;
        font-weight: 600;
        font-size: .9rem;
        background: var(--clr-bg);
        color: #374151;
        border: 1.5px solid var(--clr-border);
        display: flex; align-items: center; gap: 8px;
        text-decoration: none;
        transition: background .15s;
    }
    .btn-receipt-back:hover { background: #f3f4f6; color: #111; }

    @@media (max-width: 576px) {
        .receipt-banner { padding: 20px 18px 16px; }
        .route-row, .stats-row, .detail-list, .price-box, .action-bar {
            padding-left: 16px; padding-right: 16px;
        }
        .stats-row { flex-wrap: wrap; }
        .stat-chip { min-width: calc(50% - 6px); }
        .action-bar { flex-direction: column-reverse; }
        .btn-receipt-back { justify-content: center; }
    }
</style>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">
            <div class="receipt-card">

                <!-- Banner -->
                <div class="receipt-banner">
                    <div class="d-flex align-items-center gap-3">
                        <div class="check-wrap"><i class="bi bi-check-lg"></i></div>
                        <div>
                            <h5>Đặt chuyến thành công!</h5>
                            <small>Chúng tôi đã ghi nhận yêu cầu của bạn</small>
                        </div>
                    </div>
                    <div class="id-badge"><i class="bi bi-hash"></i> @Model.IdChuyenDi</div>
                </div>

                <!-- Route -->
                <div class="route-row">
                    <div class="route-point">
                        <div class="label text-success"><i class="bi bi-circle-fill" style="font-size:.55rem"></i> Đón</div>
                        <div class="addr">@Model.DiemDon</div>
                    </div>
                    <div class="route-divider">
                        <span></span><span></span>
                        <i class="bi bi-arrow-right arrow-icon"></i>
                        <span></span><span></span>
                    </div>
                    <div class="route-point">
                        <div class="label text-danger"><i class="bi bi-geo-alt-fill" style="font-size:.65rem"></i> Đến</div>
                        <div class="addr">@Model.DiemDen</div>
                    </div>
                </div>

                <!-- Stats -->
                <div class="stats-row">
                    <div class="stat-chip">
                        <div class="stat-icon text-primary"><i class="bi bi-signpost-2"></i></div>
                        <div class="stat-val">
                            @if (Model.KhoangCachKm > 0)
                            { @Model.KhoangCachKm.ToString("0.#") }
                            else
                            { <span style="font-size:.9rem">—</span> }
                        </div>
                        <div class="stat-unit">km</div>
                    </div>
                    <div class="stat-chip">
                        <div class="stat-icon text-warning"><i class="bi bi-clock"></i></div>
                        <div class="stat-val">
                            @if (Model.ThoiGianDuTinhPhut > 0)
                            { @Model.ThoiGianDuTinhPhut }
                            else
                            { <span style="font-size:.9rem">—</span> }
                        </div>
                        <div class="stat-unit">phút</div>
                    </div>
                    <div class="stat-chip">
                        <div class="stat-icon text-info"><i class="bi @iconXe"></i></div>
                        <div class="stat-val" style="font-size:1rem">@tenLoaiXe</div>
                        <div class="stat-unit">loại xe</div>
                    </div>
                </div>

                <!-- Details -->
                <div class="detail-list">
                    <div class="detail-row">
                        <span class="d-key"><i class="bi bi-calendar-event text-warning"></i> Thời gian đón</span>
                        <span class="d-val">@Model.ThoiGianDon.ToString("HH:mm — dd/MM/yyyy")</span>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(Model.GhiChu))
                    {
                        <div class="detail-row">
                            <span class="d-key"><i class="bi bi-pencil text-secondary"></i> Ghi chú</span>
                            <span class="d-val">@Model.GhiChu</span>
                        </div>
                    }
                </div>

                <!-- Price box -->
                <div class="price-box">
                    <div class="fw-bold mb-2" style="font-size:.82rem; text-transform:uppercase; letter-spacing:.06em; color:#374151;">
                        <i class="bi bi-receipt me-1 text-primary"></i>Chi tiết báo giá
                    </div>

                    @if (Model.KhoangCachKm > 0)
                    {
                        <div class="price-row">
                            <span>Đơn giá (@tenLoaiXe)</span>
                            <span>@Model.GiaPerKm.ToString("N0") đ/km</span>
                        </div>
                        <div class="price-row">
                            <span>Khoảng cách</span>
                            <span>@Model.KhoangCachKm.ToString("0.#") km</span>
                        </div>
                        <div class="price-row">
                            <span>Thành tiền</span>
                            <span>@((Model.KhoangCachKm > 0 ? (decimal)Model.KhoangCachKm * Model.GiaPerKm : 0).ToString("N0")) đ</span>
                        </div>
                        @if (Model.ApDungGiaToiThieu)
                        {
                            <div class="price-row">
                                <span>Áp dụng <span class="badge-min">Giá tối thiểu</span></span>
                                <span class="text-warning fw-semibold">+</span>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="price-row">
                            <small class="text-muted fst-italic">Không thể tính khoảng cách tự động.</small>
                        </div>
                    }

                    <div class="price-row total">
                        <span>Giá tạm tính</span>
                        <span>
                            @if (Model.GiaTamTinh > 0)
                            { @($"{Model.GiaTamTinh:N0} đ") }
                            else
                            { <span class="text-muted fw-normal" style="font-size:.85rem">Chờ xác nhận</span> }
                        </span>
                    </div>

                    <div class="mt-2" style="font-size:.75rem; color:#9ca3af;">
                        * Giá thực tế có thể thay đổi theo quãng đường thực tế và phụ phí phát sinh.
                    </div>
                </div>

                <!-- Action bar -->
                <div class="action-bar">
                    <a asp-action="Index" asp-controller="Home" class="btn-receipt-back">
                        <i class="bi bi-house"></i> Trang chủ
                    </a>
                    @if (coToaDo)
                    {
                        <a asp-action="baoGiaMap" asp-controller="Home"
                           asp-route-IdChuyenDi="@Model.IdChuyenDi"
                           class="btn-receipt-map">
                            <i class="bi bi-map"></i> Xem bản đồ cao cấp
                        </a>
                    }
                    else
                    {
                        <span class="btn-receipt-map opacity-50" title="Không thể tải bản đồ do không lấy được tọa độ">
                            <i class="bi bi-map"></i> Bản đồ không khả dụng
                        </span>
                    }
                </div>

            </div>
        </div>
    </div>
</div>
