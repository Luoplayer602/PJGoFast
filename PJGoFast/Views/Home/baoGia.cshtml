@using PJGoFast.Models.Enums
@model BaoGiaVM

@{
    ViewData["Title"] = "Báo giá chuyến đi";
    var userAgent = Context.Request.Headers["User-Agent"].ToString().ToLower();
    var isMobile = userAgent.Contains("mobi") || userAgent.Contains("android") || userAgent.Contains("iphone");
    Layout = isMobile ? "_LayoutMobile" : "_Layout";
    bool coToaDo = Model.DonLat != 0 && Model.DenLat != 0;
}

<style>
    .quote-page {
        display: grid;
        place-items: center;
    }

    .quote-card {
        width: min(760px, 100%);
        background: #fff;
        border-radius: 24px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 14px 32px rgba(15,23,42,.08);
        overflow: hidden;
    }

    .quote-hero {
        padding: 24px;
        color: #fff;
        background: linear-gradient(160deg, #0f172a, #1d4ed8 72%, #60a5fa);
    }

    .quote-hero h1 {
        margin: 0 0 8px;
        font-size: 1.5rem;
        font-weight: 800;
    }

    .quote-body {
        padding: 22px 24px 24px;
        display: grid;
        gap: 18px;
    }

    .info-block {
        background: #f8fbff;
        border-radius: 20px;
        border: 1px solid #e2e8f0;
        padding: 18px;
    }

    .info-block h2 {
        margin: 0 0 12px;
        font-size: .84rem;
        text-transform: uppercase;
        letter-spacing: .06em;
        color: #64748b;
        font-weight: 800;
    }

    .info-item + .info-item {
        margin-top: 10px;
    }

    .info-item small {
        display: block;
        color: #94a3b8;
        margin-bottom: 3px;
    }

    .info-item strong {
        display: block;
        color: #0f172a;
    }

    .actions {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 10px;
    }

    .actions .btn {
        border-radius: 16px;
        padding: 12px 16px;
        font-weight: 800;
    }

    @@media (max-width: 768px) {
        .actions {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="quote-page">
    <div class="quote-card">
        <div class="quote-hero">
            <h1>Xem báo giá trước khi phát hành chuyến</h1>
            <div>Chuyến hiện đang ở trạng thái <strong>CHO</strong>. Chỉ khi bạn xác nhận thì hệ thống mới chuyển chuyến sang trạng thái <strong>MOI</strong>.</div>
        </div>

        <div class="quote-body">
            <div class="info-block">
                <h2>Lộ trình</h2>
                <div class="info-item"><small>Điểm đón</small><strong>@Model.DiemDon</strong></div>
                <div class="info-item"><small>Điểm đến</small><strong>@Model.DiemDen</strong></div>
                <div class="info-item"><small>Thời gian đón</small><strong>@Model.ThoiGianDon.ToString("HH:mm dd/MM/yyyy")</strong></div>
                <div class="info-item"><small>Ghi chú</small><strong>@(string.IsNullOrWhiteSpace(Model.GhiChu) ? "Không có" : Model.GhiChu)</strong></div>
            </div>

            <div class="info-block">
                <h2>Báo giá tạm tính</h2>
                <div class="info-item"><small>Khoảng cách</small><strong>@(Model.KhoangCachKm > 0 ? $"{Model.KhoangCachKm:0.#} km" : "Không xác định")</strong></div>
                <div class="info-item"><small>Thời gian dự kiến</small><strong>@(Model.ThoiGianDuTinhPhut > 0 ? $"{Model.ThoiGianDuTinhPhut} phút" : "Không xác định")</strong></div>
                <div class="info-item"><small>Giá tạm tính</small><strong>@Model.GiaTamTinh.ToString("N0") đ</strong></div>
            </div>

            <div class="actions">
                <a asp-action="Index" class="btn btn-light border">
                    <i class="bi bi-house me-1"></i> Trang chủ
                </a>
                @if (coToaDo)
                {
                    <a asp-action="baoGiaMap" asp-route-IdChuyenDi="@Model.IdChuyenDi" class="btn btn-outline-primary">
                        <i class="bi bi-map me-1"></i> Xem bản đồ
                    </a>
                }
                else
                {
                    <button type="button" class="btn btn-outline-secondary" disabled>
                        <i class="bi bi-map me-1"></i> Bản đồ không khả dụng
                    </button>
                }
                <form asp-action="XacNhanBaoGia" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="IdChuyenDi" value="@Model.IdChuyenDi" />
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-check-circle me-1"></i> Xác nhận và tạo chuyến mới
                    </button>
                </form>
            </div>

            <form asp-action="HuyChuyenDi" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="IdChuyenDi" value="@Model.IdChuyenDi" />
                <button type="submit" class="btn btn-outline-danger rounded-4 py-3 fw-bold w-100">
                    <i class="bi bi-x-circle me-1"></i> Hủy yêu cầu báo giá
                </button>
            </form>
        </div>
    </div>
</div>
