@{
    ViewData["Title"] = "Trang chủ";
}

<div class="container py-3 py-md-4">
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-3 p-md-4">
            <h1 class="h5 mb-3">Bạn muốn đi đâu?</h1>
            <form method="post" asp-controller="Home" asp-action="taoChuyenDiWDiemDen">
                <div class="input-group">
                    <span class="input-group-text bg-white">📍</span>
                    <input type="text" name="diemDen" id="diemDen" class="form-control" placeholder="Nhập điểm đến..." required />
                    <button type="submit" class="btn btn-primary px-4">Đi</button>
                </div>
            </form>
        </div>
    </div>
</div>
