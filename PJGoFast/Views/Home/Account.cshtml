@model KhachHangAccountPageVM

@{
    ViewData["Title"] = "Tài khoản";
    var userAgent = Context.Request.Headers["User-Agent"].ToString().ToLower();
    var isMobile = userAgent.Contains("mobi") || userAgent.Contains("android") || userAgent.Contains("iphone");
    Layout = isMobile ? "_LayoutMobile" : "_Layout";

    var initials = string.IsNullOrWhiteSpace(Model.KhachHang.HoVaTen) ? "?"
        : string.Join("", Model.KhachHang.HoVaTen.Trim().Split(' ')
            .Where(w => w.Length > 0)
            .TakeLast(2)
            .Select(w => w[0].ToString().ToUpper()));
}

<style>
    .account-page {
        display: grid;
        grid-template-columns: minmax(0, 1.1fr) minmax(320px, .9fr);
        gap: 18px;
    }

    .account-card {
        background: #fff;
        border-radius: 24px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 10px 28px rgba(15,23,42,.06);
        overflow: hidden;
    }

    .account-hero {
        padding: 28px 26px;
        background: linear-gradient(160deg, #0f172a, #1d4ed8 72%, #60a5fa);
        color: #fff;
    }

    .avatar-circle {
        width: 86px;
        height: 86px;
        border-radius: 50%;
        background: rgba(255,255,255,.18);
        border: 3px solid rgba(255,255,255,.24);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        font-weight: 800;
        margin-bottom: 14px;
    }

    .account-body {
        padding: 22px 24px;
        display: grid;
        gap: 18px;
    }

    .info-block {
        background: #f8fbff;
        border: 1px solid #e2e8f0;
        border-radius: 20px;
        padding: 18px;
    }

    .info-block h2 {
        margin: 0 0 12px;
        font-size: .84rem;
        text-transform: uppercase;
        letter-spacing: .06em;
        color: #64748b;
        font-weight: 800;
    }

    .info-item + .info-item {
        margin-top: 10px;
    }

    .info-item small {
        display: block;
        color: #94a3b8;
        margin-bottom: 3px;
    }

    .info-item strong {
        display: block;
        color: #0f172a;
    }

    .form-control, .form-select {
        border-radius: 16px;
        padding: 12px 14px;
    }

    .action-stack {
        display: grid;
        gap: 10px;
    }

    .action-stack .btn {
        border-radius: 16px;
        padding: 12px 16px;
        font-weight: 800;
    }

    @@media (max-width: 992px) {
        .account-page {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="account-page">
    <section class="account-card">
        <div class="account-hero">
            <div class="avatar-circle">@initials</div>
            <h1 class="h3 fw-bold mb-1">@Model.KhachHang.HoVaTen</h1>
            <div>Khách hàng từ @Model.KhachHang.NgayDangKy.ToString("MM/yyyy")</div>
        </div>
        <div class="account-body">
            <div class="info-block">
                <h2>Thông tin hiện tại</h2>
                <div class="info-item"><small>Mã khách hàng</small><strong>@Model.KhachHang.IdKH</strong></div>
                <div class="info-item"><small>Số điện thoại</small><strong>@Model.KhachHang.SDT</strong></div>
                <div class="info-item"><small>Email</small><strong>@(string.IsNullOrWhiteSpace(Model.KhachHang.Email) ? "Chưa cập nhật" : Model.KhachHang.Email)</strong></div>
                <div class="info-item"><small>Ngày sinh</small><strong>@(Model.KhachHang.NgaySinh?.ToString("dd/MM/yyyy") ?? "Chưa cập nhật")</strong></div>
            </div>

            <a asp-controller="Login" asp-action="Logout" class="btn btn-outline-danger rounded-4 py-3 fw-bold">
                <i class="bi bi-box-arrow-right me-1"></i> Đăng xuất
            </a>
        </div>
    </section>

    <section class="account-card">
        <div class="account-body">
            <div class="info-block">
                <h2>Sửa thông tin</h2>
                <form asp-action="CapNhatTaiKhoan" method="post" class="action-stack">
                    @Html.AntiForgeryToken()
                    <input class="form-control" name="HoVaTen" value="@Model.ProfileForm.HoVaTen" placeholder="Họ và tên" />
                    <input class="form-control" name="Email" value="@Model.ProfileForm.Email" placeholder="Email" />
                    <input class="form-control" type="date" name="NgaySinh" value="@Model.ProfileForm.NgaySinh?.ToString("yyyy-MM-dd")" />
                    <button type="submit" class="btn btn-primary">Lưu thông tin</button>
                </form>
            </div>

            <div class="info-block">
                <h2>Đổi mật khẩu</h2>
                <form asp-action="DoiMatKhau" method="post" class="action-stack">
                    @Html.AntiForgeryToken()
                    <input class="form-control" type="password" name="MatKhauHienTai" placeholder="Mật khẩu hiện tại" />
                    <input class="form-control" type="password" name="MatKhauMoi" placeholder="Mật khẩu mới" />
                    <input class="form-control" type="password" name="XacNhanMatKhauMoi" placeholder="Xác nhận mật khẩu mới" />
                    <button type="submit" class="btn btn-warning text-white">Đổi mật khẩu</button>
                </form>
            </div>

            <div class="info-block">
                <h2>Xóa tài khoản</h2>
                <form asp-action="XoaTaiKhoan" method="post" class="action-stack">
                    @Html.AntiForgeryToken()
                    <input class="form-control" type="password" name="MatKhauXacNhan" placeholder="Nhập mật khẩu để xác nhận" />
                    <button type="submit" class="btn btn-outline-danger" onclick="return confirm('Xác nhận xóa tài khoản? Thao tác này sẽ xóa lịch sử chuyến đã kết thúc của bạn.');">
                        Xóa tài khoản
                    </button>
                </form>
            </div>
        </div>
    </section>
</div>
