@using PJGoFast.Models.Enums
@model BaoGiaVM

@{
    ViewData["Title"] = "Bản đồ báo giá";
    var userAgent = Context.Request.Headers["User-Agent"].ToString().ToLower();
    var isMobile = userAgent.Contains("mobi") || userAgent.Contains("android") || userAgent.Contains("iphone");
    Layout = isMobile ? "_LayoutMobile" : "_Layout";
    bool coToaDo = Model.DonLat != 0 && Model.DenLat != 0;

    var staticMapUrl = coToaDo
        ? $"https://rsapi.goong.io/staticmap/route" +
          $"?origin={Model.DonLat.ToString(System.Globalization.CultureInfo.InvariantCulture)}" +
          $",{Model.DonLng.ToString(System.Globalization.CultureInfo.InvariantCulture)}" +
          $"&destination={Model.DenLat.ToString(System.Globalization.CultureInfo.InvariantCulture)}" +
          $",{Model.DenLng.ToString(System.Globalization.CultureInfo.InvariantCulture)}" +
          $"&vehicle=car" +
          $"&api_key={Model.GoongApiKey}"
        : "";
}

<style>
    .map-quote-page {
        display: grid;
        grid-template-columns: minmax(0, 1.2fr) minmax(300px, .8fr);
        gap: 18px;
    }

    .map-card, .side-card {
        background: #fff;
        border-radius: 24px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 10px 28px rgba(15,23,42,.06);
        overflow: hidden;
    }

    .map-head {
        padding: 18px 20px;
        background: linear-gradient(160deg, #0f172a, #1d4ed8 72%, #60a5fa);
        color: #fff;
        font-weight: 800;
    }

    .map-body {
        padding: 20px;
    }

    .map-body img {
        width: 100%;
        border-radius: 18px;
        display: block;
    }

    .info-block {
        background: #f8fbff;
        border-radius: 20px;
        border: 1px solid #e2e8f0;
        padding: 18px;
    }

    .info-block h2 {
        margin: 0 0 12px;
        font-size: .84rem;
        text-transform: uppercase;
        letter-spacing: .06em;
        color: #64748b;
        font-weight: 800;
    }

    .info-item + .info-item {
        margin-top: 10px;
    }

    .info-item small {
        display: block;
        color: #94a3b8;
        margin-bottom: 3px;
    }

    .info-item strong {
        display: block;
        color: #0f172a;
    }

    .action-stack {
        display: grid;
        gap: 10px;
    }

    .action-stack .btn {
        border-radius: 16px;
        padding: 12px 16px;
        font-weight: 800;
    }

    @@media (max-width: 992px) {
        .map-quote-page {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="map-quote-page">
    <section class="map-card">
        <div class="map-head">Tuyến đường dự kiến trên bản đồ</div>
        <div class="map-body">
            @if (coToaDo)
            {
                <img src="@staticMapUrl" alt="Bản đồ tuyến đường" />
            }
            else
            {
                <div class="info-block">Không thể tải bản đồ cho tuyến đường này.</div>
            }
        </div>
    </section>

    <section class="side-card">
        <div class="map-body d-grid gap-3">
            <div class="info-block">
                <h2>Trạng thái hiện tại</h2>
                <div class="info-item"><small>Luồng tạo chuyến</small><strong>Chuyến vẫn đang ở trạng thái CHO cho đến khi bạn xác nhận.</strong></div>
                <div class="info-item"><small>Giá tạm tính</small><strong>@Model.GiaTamTinh.ToString("N0") đ</strong></div>
                <div class="info-item"><small>Khoảng cách</small><strong>@(Model.KhoangCachKm > 0 ? $"{Model.KhoangCachKm:0.#} km" : "Không xác định")</strong></div>
            </div>

            <div class="action-stack">
                <a asp-action="baoGia" asp-route-IdChuyenDi="@Model.IdChuyenDi" class="btn btn-light border">
                    <i class="bi bi-arrow-left me-1"></i> Quay lại báo giá
                </a>
                <form asp-action="XacNhanBaoGia" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="IdChuyenDi" value="@Model.IdChuyenDi" />
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-circle me-1"></i> Xác nhận và tạo chuyến mới
                    </button>
                </form>
                <form asp-action="HuyChuyenDi" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="IdChuyenDi" value="@Model.IdChuyenDi" />
                    <button type="submit" class="btn btn-outline-danger">
                        <i class="bi bi-x-circle me-1"></i> Hủy yêu cầu báo giá
                    </button>
                </form>
            </div>
        </div>
    </section>
</div>
