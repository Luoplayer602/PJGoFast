@using PJGoFast.Models.Enums
@using PJGoFast.ViewModels
@model BaoGiaVM

@{
    ViewData["Title"] = "Bản Đồ Chuyến Đi";
    Layout = "_ImportBootstrap"; // Giữ layout, nhưng ẩn footer nếu cần

    var tenLoaiXe = Model.LoaiXeYeuCau switch
    {
        LoaiXe.XeMay   => "Xe máy",
        LoaiXe.Sedan   => "Xe sedan",
        LoaiXe.SUV     => "Xe SUV",
        LoaiXe.BayCho  => "Xe 7 chỗ",
        LoaiXe.TaiNho  => "Xe tải nhỏ",
        _              => Model.LoaiXeYeuCau.ToString()
    };
    var iconXe = Model.LoaiXeYeuCau switch
    {
        LoaiXe.XeMay  => "bi-bicycle",
        LoaiXe.TaiNho => "bi-truck",
        _             => "bi-car-front-fill"
    };

    bool coToaDo = Model.DonLat != 0 && Model.DenLat != 0;
}

@section Styles {
<link href="https://cdn.goong.io/js/goong-map-js/v1.0.4/goong-map.css" rel="stylesheet" />
<style>
    /* ── Reset / full-height map ── */
    html, body { height: 100%; }

    .map-page-wrapper {
        position: relative;
        width: 100%;
        height: calc(100vh - 56px); /* 56px = chiều cao navbar mặc định Bootstrap */
        overflow: hidden;
    }

    #goong-map {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
    }

    /* ── Floating panel ── */
    .map-panel {
        position: absolute;
        top: 20px;
        left: 20px;
        width: 340px;
        max-height: calc(100vh - 96px);
        overflow-y: auto;
        background: rgba(255, 255, 255, 0.97);
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
        border-radius: 20px;
        box-shadow: 0 8px 40px rgba(0,0,0,.18), 0 2px 8px rgba(0,0,0,.08);
        z-index: 10;
        animation: slideInPanel .4s cubic-bezier(.22,1,.36,1) both;
        scrollbar-width: thin;
    }
    .map-panel::-webkit-scrollbar { width: 4px; }
    .map-panel::-webkit-scrollbar-thumb { background: #d1d5db; border-radius: 4px; }

    @@keyframes slideInPanel {
        from { opacity: 0; transform: translateX(-28px); }
        to   { opacity: 1; transform: translateX(0);     }
    }

    /* ── Panel header ── */
    .panel-header {
        background: linear-gradient(135deg, #1d4ed8, #3b82f6);
        border-radius: 20px 20px 0 0;
        padding: 18px 20px 16px;
        color: #fff;
    }
    .panel-header .title { font-size: 1rem; font-weight: 700; }
    .panel-header .sub   { font-size: .78rem; opacity: .78; }
    .panel-header .id-chip {
        background: rgba(255,255,255,.15);
        border-radius: 6px;
        padding: 2px 10px;
        font-size: .72rem;
        font-family: monospace;
        margin-top: 8px;
        display: inline-block;
    }

    /* ── Panel body ── */
    .panel-body { padding: 16px 18px; }

    /* ── Route visual ── */
    .route-visual { margin-bottom: 14px; }
    .rv-point {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        padding: 10px 12px;
        border-radius: 12px;
        background: #f9fafb;
        font-size: .84rem;
    }
    .rv-point + .rv-point { margin-top: 6px; }
    .rv-dot {
        width: 28px; height: 28px;
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-size: 11px;
        flex-shrink: 0;
        margin-top: 1px;
    }
    .rv-dot.pickup  { background: #dcfce7; color: #16a34a; }
    .rv-dot.dropoff { background: #fee2e2; color: #dc2626; }
    .rv-label { font-size: .7rem; color: #6b7280; font-weight: 600; text-transform: uppercase; letter-spacing:.05em; }
    .rv-addr  { font-weight: 600; color: #111827; line-height: 1.35; word-break: break-word; }

    .rv-connector {
        display: flex;
        align-items: center;
        padding: 3px 0 3px 24px;
        gap: 2px;
        color: #9ca3af;
        font-size: .7rem;
    }
    .rv-connector::before {
        content: '';
        display: block;
        width: 2px; height: 18px;
        background: linear-gradient(to bottom, #22c55e, #ef4444);
        border-radius: 2px;
        margin-right: 8px;
        flex-shrink: 0;
    }

    /* ── Stats ── */
    .stats-mini {
        display: flex;
        gap: 8px;
        margin-bottom: 14px;
    }
    .smc {
        flex: 1;
        background: #f3f4f6;
        border-radius: 12px;
        padding: 10px 8px;
        text-align: center;
    }
    .smc .val { font-size: 1.1rem; font-weight: 800; color: #111; }
    .smc .lbl { font-size: .68rem; color: #6b7280; margin-top: 1px; }
    .smc .ico { font-size: .95rem; margin-bottom: 3px; }

    /* ── Price box ── */
    .price-mini {
        background: linear-gradient(135deg, #eff6ff, #f0fdf4);
        border: 1.5px solid #bfdbfe;
        border-radius: 14px;
        padding: 14px 16px;
        margin-bottom: 14px;
    }
    .pm-row {
        display: flex;
        justify-content: space-between;
        font-size: .82rem;
        padding: 3px 0;
        color: #374151;
    }
    .pm-row.total {
        border-top: 1.5px dashed #93c5fd;
        margin-top: 8px;
        padding-top: 10px;
        font-size: 1.1rem;
        font-weight: 800;
        color: #1d4ed8;
    }

    /* ── Buttons ── */
    .panel-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 7px;
        width: 100%;
        padding: 10px 0;
        border-radius: 12px;
        font-weight: 700;
        font-size: .87rem;
        text-decoration: none;
        transition: filter .15s, transform .1s;
        border: none;
        cursor: pointer;
    }
    .panel-btn:hover { filter: brightness(1.07); transform: translateY(-1px); }
    .panel-btn-back {
        background: #f3f4f6;
        color: #374151;
        border: 1.5px solid #e5e7eb;
        margin-top: 8px;
    }
    .panel-btn-back:hover { background: #e5e7eb; color: #111; }

    /* ── Loading overlay ── */
    #map-loading {
        position: absolute;
        inset: 0;
        background: #e8edf2;
        z-index: 5;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 14px;
        transition: opacity .4s;
    }
    #map-loading.hidden { opacity: 0; pointer-events: none; }

    /* ── Error banner ── */
    .map-error {
        position: absolute;
        bottom: 20px; left: 50%;
        transform: translateX(-50%);
        background: #fef2f2;
        border: 1.5px solid #fca5a5;
        color: #991b1b;
        border-radius: 12px;
        padding: 10px 20px;
        font-size: .85rem;
        z-index: 15;
        display: none;
    }

    /* ── Status badges ── */
    .status-badge {
        position: absolute;
        bottom: 30px;
        right: 20px;
        background: rgba(255,255,255,.95);
        backdrop-filter: blur(10px);
        border-radius: 12px;
        padding: 8px 14px;
        font-size: .8rem;
        font-weight: 600;
        z-index: 10;
        box-shadow: 0 2px 12px rgba(0,0,0,.12);
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .status-dot {
        width: 8px; height: 8px;
        border-radius: 50%;
        animation: pulse 1.5s infinite;
    }
    @@keyframes pulse {
        0%, 100% { opacity: 1; transform: scale(1);    }
        50%       { opacity: .5; transform: scale(1.3); }
    }

    @@media (max-width: 576px) {
        .map-page-wrapper { height: calc(100vh - 56px); }
        .map-panel {
            top: auto; bottom: 0; left: 0; right: 0;
            width: 100%;
            border-radius: 20px 20px 0 0;
            max-height: 55vh;
            animation: slideUpPanel .4s cubic-bezier(.22,1,.36,1) both;
        }
        .panel-header { border-radius: 20px 20px 0 0; }
        @@keyframes slideUpPanel {
            from { opacity: 0; transform: translateY(40px); }
            to   { opacity: 1; transform: translateY(0);    }
        }
    }
</style>
}

<div class="map-page-wrapper">

    <!-- Loading overlay -->
    <div id="map-loading">
        <div class="spinner-border text-primary" role="status" style="width:2.5rem;height:2.5rem;"></div>
        <div style="color:#374151;font-weight:600;">Đang tải bản đồ...</div>
    </div>

    <!-- Map container -->
    <div id="goong-map"></div>

    @if (!coToaDo)
    {
        <!-- No coordinates fallback -->
        <div class="map-error" style="display:block;">
            <i class="bi bi-exclamation-triangle me-2"></i>
            Không thể xác định tọa độ địa chỉ. Bản đồ hiển thị khu vực mặc định.
        </div>
    }

    <!-- Status badge (shown while loading route) -->
    <div class="status-badge" id="route-status" style="display:none;">
        <div class="status-dot" style="background:#3b82f6;"></div>
        <span id="route-status-text">Đang tải tuyến đường...</span>
    </div>

    <!-- Floating info panel -->
    <div class="map-panel">

        <!-- Header -->
        <div class="panel-header">
            <div class="d-flex align-items-center gap-2 mb-1">
                <i class="bi bi-map-fill"></i>
                <span class="title">Chi tiết chuyến đi</span>
            </div>
            <div class="sub">Tuyến đường ngắn nhất được đề xuất</div>
            <div class="id-chip"><i class="bi bi-hash"></i> @Model.IdChuyenDi</div>
        </div>

        <!-- Body -->
        <div class="panel-body">

            <!-- Route visual -->
            <div class="route-visual">
                <div class="rv-point">
                    <div class="rv-dot pickup"><i class="bi bi-circle-fill" style="font-size:8px"></i></div>
                    <div>
                        <div class="rv-label">Điểm đón</div>
                        <div class="rv-addr">@Model.DiemDon</div>
                    </div>
                </div>
                <div class="rv-connector">quãng đường ngắn nhất</div>
                <div class="rv-point">
                    <div class="rv-dot dropoff"><i class="bi bi-geo-alt-fill" style="font-size:10px"></i></div>
                    <div>
                        <div class="rv-label">Điểm đến</div>
                        <div class="rv-addr">@Model.DiemDen</div>
                    </div>
                </div>
            </div>

            <!-- Stats -->
            <div class="stats-mini">
                <div class="smc">
                    <div class="ico text-primary"><i class="bi bi-signpost-2"></i></div>
                    <div class="val" id="panel-km">
                        @(Model.KhoangCachKm > 0 ? Model.KhoangCachKm.ToString("0.#") : "—")
                    </div>
                    <div class="lbl">km</div>
                </div>
                <div class="smc">
                    <div class="ico text-warning"><i class="bi bi-clock"></i></div>
                    <div class="val" id="panel-min">
                        @(Model.ThoiGianDuTinhPhut > 0 ? Model.ThoiGianDuTinhPhut.ToString() : "—")
                    </div>
                    <div class="lbl">phút</div>
                </div>
                <div class="smc">
                    <div class="ico text-info"><i class="bi @iconXe"></i></div>
                    <div class="val" style="font-size:.78rem;line-height:1.2;">@tenLoaiXe</div>
                    <div class="lbl">loại xe</div>
                </div>
            </div>

            <!-- Price -->
            <div class="price-mini">
                <div style="font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:#374151;margin-bottom:8px;">
                    <i class="bi bi-receipt me-1 text-primary"></i> Báo giá tạm tính
                </div>
                @if (Model.KhoangCachKm > 0)
                {
                    <div class="pm-row">
                        <span>Đơn giá</span>
                        <span>@Model.GiaPerKm.ToString("N0") đ/km</span>
                    </div>
                    <div class="pm-row">
                        <span>Khoảng cách</span>
                        <span>@Model.KhoangCachKm.ToString("0.#") km</span>
                    </div>
                    @if (Model.ApDungGiaToiThieu)
                    {
                        <div class="pm-row">
                            <span><span style="background:#fef3c7;color:#92400e;border-radius:10px;padding:1px 8px;font-size:.7rem;">Giá tối thiểu</span></span>
                        </div>
                    }
                }
                <div class="pm-row total">
                    <span>Tổng cộng</span>
                    <span>
                        @if (Model.GiaTamTinh > 0)
                        { @($"{Model.GiaTamTinh:N0} đ") }
                        else
                        { <span class="text-muted fw-normal" style="font-size:.85rem">Chờ xác nhận</span> }
                    </span>
                </div>
            </div>

            <!-- Thời gian đón -->
            <div style="background:#f9fafb;border-radius:12px;padding:10px 14px;font-size:.83rem;margin-bottom:12px;">
                <span class="text-muted"><i class="bi bi-calendar-event me-1 text-warning"></i>Đón lúc:</span>
                <span class="fw-semibold ms-1">@Model.ThoiGianDon.ToString("HH:mm — dd/MM/yyyy")</span>
            </div>

            <!-- Buttons -->
            <a asp-action="baoGia" asp-controller="Home"
               asp-route-IdChuyenDi="@Model.IdChuyenDi"
               class="panel-btn panel-btn-back">
                <i class="bi bi-arrow-left"></i> Quay lại báo giá
            </a>
            <a asp-action="Index" asp-controller="Home"
               class="panel-btn panel-btn-back mt-2">
                <i class="bi bi-house"></i> Trang chủ
            </a>

        </div>
    </div>

</div>

@section Scripts {
<script src="https://cdn.goong.io/js/goong-map-js/v1.0.4/goong-map.js"></script>
<script>
    // ── Tọa độ từ server ──────────────────────────────────────────────────
    const DON_LAT  = @Model.DonLat.ToString(System.Globalization.CultureInfo.InvariantCulture);
    const DON_LNG  = @Model.DonLng.ToString(System.Globalization.CultureInfo.InvariantCulture);
    const DEN_LAT  = @Model.DenLat.ToString(System.Globalization.CultureInfo.InvariantCulture);
    const DEN_LNG  = @Model.DenLng.ToString(System.Globalization.CultureInfo.InvariantCulture);
    const HAS_COORDS = DON_LAT !== 0 && DEN_LAT !== 0;

    // ── API Keys ──────────────────────────────────────────────────────────
    const MAP_KEY  = '@Model.GoongMapKey';
    const API_KEY  = '@Model.GoongApiKey';

    // ── Trung điểm để căn map ──────────────────────────────────────────────
    const centerLng = HAS_COORDS ? (DON_LNG + DEN_LNG) / 2 : 105.8412;
    const centerLat = HAS_COORDS ? (DON_LAT + DEN_LAT) / 2 : 21.0278;

    // ── Giải mã polyline (chuẩn Google Encoded Polyline) ──────────────────
    function decodePolyline(encoded) {
        let index = 0, lat = 0, lng = 0, coords = [];
        while (index < encoded.length) {
            let b, shift = 0, result = 0;
            do { b = encoded.charCodeAt(index++) - 63; result |= (b & 0x1f) << shift; shift += 5; }
            while (b >= 0x20);
            lat += (result & 1) ? ~(result >> 1) : (result >> 1);

            shift = 0; result = 0;
            do { b = encoded.charCodeAt(index++) - 63; result |= (b & 0x1f) << shift; shift += 5; }
            while (b >= 0x20);
            lng += (result & 1) ? ~(result >> 1) : (result >> 1);

            coords.push([lng / 1e5, lat / 1e5]);
        }
        return coords;
    }

    // ── Thêm route lên map ────────────────────────────────────────────────
    function addRoute(map, coords) {
        // Lớp bóng (glow effect)
        map.addSource('route-glow', {
            type: 'geojson',
            data: { type: 'Feature', geometry: { type: 'LineString', coordinates: coords } }
        });
        map.addLayer({
            id: 'route-glow', type: 'line', source: 'route-glow',
            layout: { 'line-join': 'round', 'line-cap': 'round' },
            paint: { 'line-color': '#3b82f6', 'line-width': 14, 'line-opacity': 0.18, 'line-blur': 4 }
        });

        // Lớp đường chính
        map.addSource('route', {
            type: 'geojson',
            data: { type: 'Feature', geometry: { type: 'LineString', coordinates: coords } }
        });
        map.addLayer({
            id: 'route', type: 'line', source: 'route',
            layout: { 'line-join': 'round', 'line-cap': 'round' },
            paint: { 'line-color': '#2563eb', 'line-width': 5, 'line-opacity': 0.9 }
        });

        // Đường dashed bên trên (hiệu ứng chuyển động)
        map.addLayer({
            id: 'route-dash', type: 'line', source: 'route',
            layout: { 'line-join': 'round', 'line-cap': 'butt' },
            paint: {
                'line-color': '#fff',
                'line-width': 2,
                'line-opacity': 0.6,
                'line-dasharray': [0, 2, 4]
            }
        });
    }

    // ── Thêm marker tùy chỉnh ────────────────────────────────────────────
    function addMarker(map, lngLat, type) {
        const el = document.createElement('div');
        el.style.cssText = `
            width: 36px; height: 36px; border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            box-shadow: 0 3px 12px rgba(0,0,0,.25);
            border: 3px solid #fff;
            font-size: 15px;
            cursor: default;
        `;
        if (type === 'pickup') {
            el.style.background = '#16a34a';
            el.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="white" viewBox="0 0 16 16"><circle cx="8" cy="8" r="4"/></svg>';
        } else {
            el.style.background = '#dc2626';
            el.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="white" viewBox="0 0 16 16"><path d="M8 16s6-5.686 6-10A6 6 0 0 0 2 6c0 4.314 6 10 6 10zm0-7a3 3 0 1 1 0-6 3 3 0 0 1 0 6z"/></svg>';
        }
        new goongjs.Marker(el).setLngLat(lngLat).addTo(map);
    }

    // ── Init map ──────────────────────────────────────────────────────────
    goongjs.accessToken = MAP_KEY;

    const map = new goongjs.Map({
        container: 'goong-map',
        style: 'https://tiles.goong.io/assets/goong_map_web.json',
        center: [centerLng, centerLat],
        zoom: 12,
        attributionControl: false
    });

    // Thêm điều khiển zoom
    map.addControl(new goongjs.NavigationControl(), 'bottom-right');

    // ── Khi map load xong ─────────────────────────────────────────────────
    map.on('load', async () => {
        // Ẩn loading overlay
        document.getElementById('map-loading').classList.add('hidden');

        if (!HAS_COORDS) return;

        // Ghim 2 marker
        addMarker(map, [DON_LNG, DON_LAT], 'pickup');
        addMarker(map, [DEN_LNG, DEN_LAT], 'dropoff');

        // Fit bounds để hiển thị cả 2 điểm
        const bounds = new goongjs.LngLatBounds();
        bounds.extend([DON_LNG, DON_LAT]);
        bounds.extend([DEN_LNG, DEN_LAT]);
        map.fitBounds(bounds, { padding: { top: 80, bottom: 80, left: 380, right: 60 } });

        // Hiển thị status
        const statusBadge = document.getElementById('route-status');
        statusBadge.style.display = 'flex';

        // Gọi Directions API để lấy tuyến đường thực tế
        try {
            const url = `https://rsapi.goong.io/v2/direction` +
                        `?origin=${DON_LAT},${DON_LNG}` +
                        `&destination=${DEN_LAT},${DEN_LNG}` +
                        `&vehicle=car` +
                        `&api_key=${API_KEY}`;

            const res  = await fetch(url);
            const data = await res.json();

            if (data.routes && data.routes.length > 0) {
                const encoded = data.routes[0].overview_polyline.points;
                const coords  = decodePolyline(encoded);
                addRoute(map, coords);

                // Cập nhật status
                document.getElementById('route-status-text').textContent = 'Tuyến đường tối ưu';
                statusBadge.querySelector('.status-dot').style.background   = '#22c55e';
                statusBadge.querySelector('.status-dot').style.animation    = 'none';

                // Fit lại bounds theo route thực tế
                const routeBounds = coords.reduce((b, c) => b.extend(c), new goongjs.LngLatBounds(coords[0], coords[0]));
                map.fitBounds(routeBounds, { padding: { top: 80, bottom: 80, left: 380, right: 60 } });

            } else {
                throw new Error('No routes returned');
            }
        } catch (e) {
            // Fallback: vẽ đường thẳng
            addRoute(map, [[DON_LNG, DON_LAT], [DEN_LNG, DEN_LAT]]);
            document.getElementById('route-status-text').textContent = 'Đường thẳng ước tính';
            statusBadge.querySelector('.status-dot').style.background = '#f59e0b';
            statusBadge.querySelector('.status-dot').style.animation  = 'none';
        }
    });

    // Popup khi click vào route
    map.on('click', 'route', (e) => {
        new goongjs.Popup()
            .setLngLat(e.lngLat)
            .setHTML(`<div style="font-size:.82rem;font-weight:600;color:#1d4ed8;">
                        <i class="bi bi-signpost-2"></i>
                        Tuyến đường ngắn nhất
                      </div>`)
            .addTo(map);
    });
    map.on('mouseenter', 'route', () => map.getCanvas().style.cursor = 'pointer');
    map.on('mouseleave', 'route', () => map.getCanvas().style.cursor = '');
</script>
}
