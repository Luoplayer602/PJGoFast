@using PJGoFast.Models.Enums
@using PJGoFast.ViewModels
@model BaoGiaVM

@{
    ViewData["Title"] = "Bản Đồ Chuyến Đi";
        var userAgent = Context.Request.Headers["User-Agent"].ToString().ToLower();
    
    // Nhận diện các từ khóa phổ biến của thiết bị di động
    bool isMobile = userAgent.Contains("mobi") || 
                    userAgent.Contains("android") || 
                    userAgent.Contains("iphone");

    // Chọn layout tương ứng
    if (isMobile)
    {
        Layout = "_LayoutMobile"; // Dùng cho điện thoại
    }
    else
    {
        Layout = "_Layout";       // Dùng cho máy tính (Desktop)
    }

    var tenLoaiXe = Model.LoaiXeYeuCau switch
    {
        LoaiXe.XeMay   => "Xe máy",
        LoaiXe.Sedan   => "Xe sedan",
        LoaiXe.SUV     => "Xe SUV",
        LoaiXe.BayCho  => "Xe 7 chỗ",
        LoaiXe.TaiNho  => "Xe tải nhỏ",
        _              => Model.LoaiXeYeuCau.ToString()
    };
    var iconXe = Model.LoaiXeYeuCau switch
    {
        LoaiXe.XeMay  => "bi-bicycle",
        LoaiXe.TaiNho => "bi-truck",
        _             => "bi-car-front-fill"
    };

    bool coToaDo = Model.DonLat != 0 && Model.DenLat != 0;

    var staticMapUrl = coToaDo
        ? $"https://rsapi.goong.io/staticmap/route" +
          $"?origin={Model.DonLat.ToString(System.Globalization.CultureInfo.InvariantCulture)}" +
          $",{Model.DonLng.ToString(System.Globalization.CultureInfo.InvariantCulture)}" +
          $"&destination={Model.DenLat.ToString(System.Globalization.CultureInfo.InvariantCulture)}" +
          $",{Model.DenLng.ToString(System.Globalization.CultureInfo.InvariantCulture)}" +
          $"&vehicle=car" +
          $"&api_key={Model.GoongApiKey}"
        : "";
}

<style>
    :root {
        --clr-accent:  #2563eb;
        --clr-bg:      #f0f4f8;
        --clr-card:    #ffffff;
        --clr-border:  #e5e7eb;
        --clr-muted:   #6b7280;
    }
    body { background: var(--clr-bg); }

    .map-layout { display: flex; gap: 24px; align-items: flex-start; padding: 32px 0; }

    .map-card { flex: 1; background: var(--clr-card); border-radius: 20px; box-shadow: 0 4px 32px rgba(37,99,235,.10); overflow: hidden; animation: fadeIn .4s ease both; min-width: 0; }
    .map-card-header { padding: 14px 20px; background: linear-gradient(135deg, #1d4ed8, #3b82f6); color: #fff; display: flex; align-items: center; gap: 10px; font-weight: 700; font-size: .92rem; }
    .map-card-header small { opacity: .78; font-weight: 400; font-size: .75rem; }

    .map-img-wrap { position: relative; width: 100%; background: #dde3ec; min-height: 420px; display: flex; align-items: center; justify-content: center; }
    .map-img-wrap img { width: 100%; height: auto; display: block; }

    .map-skeleton { position: absolute; inset: 0; background: linear-gradient(90deg, #dde3ec 25%, #e8edf3 50%, #dde3ec 75%); background-size: 200% 100%; animation: shimmer 1.4s infinite; display: flex; align-items: center; justify-content: center; flex-direction: column; gap: 10px; color: #9ca3af; font-size: .85rem; }
    @@keyframes shimmer { from { background-position: 200% 0; } to { background-position: -200% 0; } }

    .map-legend { display: flex; gap: 20px; padding: 12px 20px; border-top: 1px solid var(--clr-border); font-size: .8rem; color: var(--clr-muted); }
    .legend-dot { width: 10px; height: 10px; border-radius: 50%; display: inline-block; margin-right: 5px; }

    /* Info panel */
    .info-panel { width: 320px; flex-shrink: 0; display: flex; flex-direction: column; gap: 14px; animation: slideIn .4s cubic-bezier(.22,1,.36,1) both; }
    @@keyframes slideIn { from { opacity: 0; transform: translateX(20px); } to { opacity: 1; transform: translateX(0); } }
    @@keyframes fadeIn  { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }

    .panel-card { background: var(--clr-card); border-radius: 16px; box-shadow: 0 2px 16px rgba(0,0,0,.06); overflow: hidden; }
    .panel-card-head { padding: 12px 16px; border-bottom: 1px solid var(--clr-border); font-size: .78rem; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; color: var(--clr-muted); display: flex; align-items: center; gap: 6px; }
    .panel-card-body { padding: 14px 16px; }

    .rv-point { display: flex; align-items: flex-start; gap: 10px; padding: 10px 12px; border-radius: 12px; background: #f9fafb; font-size: .84rem; }
    .rv-point + .rv-point { margin-top: 6px; }
    .rv-dot { width: 28px; height: 28px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 12px; flex-shrink: 0; margin-top: 2px; }
    .rv-label { font-size: .7rem; color: #6b7280; font-weight: 700; text-transform: uppercase; letter-spacing:.05em; }
    .rv-addr  { font-weight: 600; color: #111827; line-height: 1.35; word-break: break-word; }
    .rv-connector { padding: 4px 0 4px 22px; font-size: .72rem; color: #9ca3af; display: flex; align-items: center; gap: 6px; }
    .rv-connector::before { content: ''; display: inline-block; width: 2px; height: 18px; background: linear-gradient(to bottom, #22c55e, #ef4444); border-radius: 2px; margin-right: 8px; flex-shrink: 0; }

    .stats-row { display: flex; gap: 10px; }
    .stat-chip { flex: 1; background: #f9fafb; border-radius: 12px; padding: 12px 8px; text-align: center; border: 1px solid var(--clr-border); }
    .stat-chip .sv { font-size: 1.15rem; font-weight: 800; color: #111; }
    .stat-chip .sl { font-size: .68rem; color: var(--clr-muted); margin-top: 2px; }
    .stat-chip .si { font-size: .95rem; margin-bottom: 4px; }

    .pm-row { display: flex; justify-content: space-between; font-size: .83rem; padding: 4px 0; color: #374151; }
    .pm-row.total { border-top: 1.5px dashed #93c5fd; margin-top: 10px; padding-top: 12px; font-size: 1.1rem; font-weight: 800; color: #1d4ed8; }

    .btn-map { display: flex; align-items: center; justify-content: center; gap: 8px; width: 100%; padding: 11px 0; border-radius: 12px; font-weight: 700; font-size: .88rem; text-decoration: none; border: 1.5px solid var(--clr-border); background: #f9fafb; color: #374151; transition: background .15s, transform .1s; }
    .btn-map:hover { background: #f0f4f8; color: #111; transform: translateY(-1px); }

    /* Nút xóa chuyến */
    .btn-map-cancel { display: flex; align-items: center; justify-content: center; gap: 8px; width: 100%; padding: 11px 0; border-radius: 12px; font-weight: 700; font-size: .88rem; border: 1.5px solid #fca5a5; background: #fef2f2; color: #dc2626; cursor: pointer; transition: background .15s; margin-top: 8px; }
    .btn-map-cancel:hover { background: #fee2e2; }

    .no-coords-box { min-height: 420px; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 10px; color: #9ca3af; padding: 40px; text-align: center; }
    .no-coords-box i { font-size: 2.5rem; color: #d1d5db; }

    /* Confirm sheet */
    .confirm-overlay { position: fixed; inset: 0; background: rgba(0,0,0,.45); z-index: 500; display: none; align-items: flex-end; justify-content: center; }
    .confirm-overlay.show { display: flex; }
    .confirm-sheet { background: #fff; border-radius: 24px 24px 0 0; padding: 28px 24px 36px; width: 100%; max-width: 480px; animation: sheetUp .3s cubic-bezier(.22,1,.36,1) both; }
    @@keyframes sheetUp { from { transform: translateY(100%); } to { transform: translateY(0); } }
    .confirm-sheet .icon-wrap { width: 56px; height: 56px; border-radius: 50%; background: #fef2f2; color: #dc2626; display: flex; align-items: center; justify-content: center; font-size: 24px; margin: 0 auto 14px; }
    .confirm-sheet h6 { font-weight: 800; font-size: 1.05rem; text-align: center; color: #111; }
    .confirm-sheet p  { font-size: .86rem; color: #6b7280; text-align: center; margin-bottom: 20px; }
    .btn-confirm-yes { width: 100%; padding: 13px; border-radius: 14px; background: #dc2626; color: #fff; font-weight: 700; font-size: .92rem; border: none; cursor: pointer; margin-bottom: 10px; }
    .btn-confirm-no  { width: 100%; padding: 13px; border-radius: 14px; background: #f3f4f6; color: #374151; font-weight: 700; font-size: .92rem; border: 1.5px solid #e5e7eb; cursor: pointer; }

    @@media (max-width: 768px) {
        .map-layout { flex-direction: column; padding: 16px 0 24px; }
        .info-panel { width: 100%; }
        .map-img-wrap { min-height: 260px; }
    }
</style>

<div class="container-fluid px-3 px-md-4">
    <div class="map-layout">

        <!-- Map card -->
        <div class="map-card">
            <div class="map-card-header">
                <i class="bi bi-map-fill"></i>
                <div>Tuyến đường ngắn nhất<br><small>Được tính toán bởi Goong Maps</small></div>
            </div>
            <div class="map-img-wrap" id="mapWrap">
                @if (coToaDo)
                {
                    <div class="map-skeleton" id="mapSkeleton">
                        <i class="bi bi-map" style="font-size:2rem;"></i>
                        <span>Đang tải bản đồ...</span>
                    </div>
                    <img id="mapImg" src="@staticMapUrl"
                         alt="Bản đồ tuyến đường"
                         style="display:none;"
                         onload="onMapLoaded()"
                         onerror="onMapError()" />
                }
                else
                {
                    <div class="no-coords-box">
                        <i class="bi bi-geo-alt-fill"></i>
                        <div class="fw-semibold text-dark">Không thể hiển thị bản đồ</div>
                        <div style="font-size:.83rem;">Không xác định được tọa độ địa chỉ.</div>
                    </div>
                }
            </div>
            @if (coToaDo)
            {
                <div class="map-legend">
                    <span><span class="legend-dot" style="background:#22c55e;"></span>Điểm đón</span>
                    <span><span class="legend-dot" style="background:#ef4444;"></span>Điểm đến</span>
                    <span><span class="legend-dot" style="background:#2563eb;border-radius:2px;"></span>Tuyến đường</span>
                </div>
            }
        </div>

        <!-- Info panel -->
        <div class="info-panel">

            <div style="padding: 4px 0 0;">
                <div class="fw-bold" style="font-size:1.1rem; color:#111;">Chi tiết chuyến đi</div>
                <div style="font-size:.78rem; color:var(--clr-muted);">
                    <i class="bi bi-hash"></i><span style="font-family:monospace;">@Model.IdChuyenDi</span>
                </div>
            </div>

            <!-- Route -->
            <div class="panel-card">
                <div class="panel-card-head"><i class="bi bi-arrow-left-right text-primary"></i> Lộ trình</div>
                <div class="panel-card-body">
                    <div class="rv-point">
                        <div class="rv-dot" style="background:#dcfce7;color:#16a34a;"><i class="bi bi-circle-fill" style="font-size:8px;"></i></div>
                        <div><div class="rv-label">Điểm đón</div><div class="rv-addr">@Model.DiemDon</div></div>
                    </div>
                    <div class="rv-connector">tuyến ngắn nhất</div>
                    <div class="rv-point">
                        <div class="rv-dot" style="background:#fee2e2;color:#dc2626;"><i class="bi bi-geo-alt-fill" style="font-size:11px;"></i></div>
                        <div><div class="rv-label">Điểm đến</div><div class="rv-addr">@Model.DiemDen</div></div>
                    </div>
                </div>
            </div>

            <!-- Stats -->
            <div class="panel-card">
                <div class="panel-card-head"><i class="bi bi-speedometer2 text-primary"></i> Thống kê</div>
                <div class="panel-card-body">
                    <div class="stats-row">
                        <div class="stat-chip">
                            <div class="si text-primary"><i class="bi bi-signpost-2"></i></div>
                            <div class="sv">@(Model.KhoangCachKm > 0 ? Model.KhoangCachKm.ToString("0.#") : "—")</div>
                            <div class="sl">km</div>
                        </div>
                        <div class="stat-chip">
                            <div class="si text-warning"><i class="bi bi-clock"></i></div>
                            <div class="sv">@(Model.ThoiGianDuTinhPhut > 0 ? Model.ThoiGianDuTinhPhut.ToString() : "—")</div>
                            <div class="sl">phút</div>
                        </div>
                        <div class="stat-chip">
                            <div class="si text-info"><i class="bi @iconXe"></i></div>
                            <div class="sv" style="font-size:.78rem; line-height:1.2;">@tenLoaiXe</div>
                            <div class="sl">loại xe</div>
                        </div>
                    </div>
                    <div style="margin-top:12px; background:#f9fafb; border-radius:10px; padding:10px 12px; font-size:.82rem;">
                        <i class="bi bi-calendar-event me-1 text-warning"></i>
                        <span class="text-muted">Đón lúc:</span>
                        <span class="fw-semibold ms-1">@Model.ThoiGianDon.ToString("HH:mm — dd/MM/yyyy")</span>
                    </div>
                </div>
            </div>

            <!-- Price -->
            <div class="panel-card">
                <div class="panel-card-head"><i class="bi bi-receipt text-primary"></i> Báo giá tạm tính</div>
                <div class="panel-card-body">
                    @if (Model.KhoangCachKm > 0)
                    {
                        <div class="pm-row"><span>Đơn giá (@tenLoaiXe)</span><span>@Model.GiaPerKm.ToString("N0") đ/km</span></div>
                        <div class="pm-row"><span>Khoảng cách</span><span>@Model.KhoangCachKm.ToString("0.#") km</span></div>
                        @if (Model.ApDungGiaToiThieu)
                        {
                            <div class="pm-row"><span><span style="background:#fef3c7;color:#92400e;border-radius:20px;padding:2px 10px;font-size:.72rem;font-weight:600;">Giá tối thiểu</span></span></div>
                        }
                    }
                    else
                    {
                        <div class="pm-row"><small class="text-muted fst-italic">Không tính được khoảng cách.</small></div>
                    }
                    <div class="pm-row total">
                        <span>Tổng cộng</span>
                        <span>
                            @if (Model.GiaTamTinh > 0) { @($"{Model.GiaTamTinh:N0} đ") }
                            else { <span class="fw-normal text-muted" style="font-size:.85rem">Chờ xác nhận</span> }
                        </span>
                    </div>
                    <div style="font-size:.72rem; color:#9ca3af; margin-top:8px;">* Giá thực tế có thể thay đổi.</div>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.GhiChu))
            {
                <div class="panel-card">
                    <div class="panel-card-head"><i class="bi bi-pencil text-secondary"></i> Ghi chú</div>
                    <div class="panel-card-body" style="font-size:.85rem; color:#374151;">@Model.GhiChu</div>
                </div>
            }

            <a asp-action="baoGia" asp-controller="Home" asp-route-IdChuyenDi="@Model.IdChuyenDi" class="btn-map">
                <i class="bi bi-arrow-left"></i> Quay lại báo giá
            </a>
            <a asp-action="Index" asp-controller="Home" class="btn-map mt-1">
                <i class="bi bi-house"></i> Trang chủ
            </a>

            <!-- Nút xóa chuyến -->
            <button type="button" class="btn-map-cancel" onclick="showConfirm()">
                <i class="bi bi-x-circle"></i> Hủy & xóa chuyến đi này
            </button>

        </div>
    </div>
</div>

<!-- Confirm bottom sheet -->
<div class="confirm-overlay" id="confirmOverlay" onclick="hideConfirm(event)">
    <div class="confirm-sheet" onclick="event.stopPropagation()">
        <div class="icon-wrap"><i class="bi bi-trash3-fill"></i></div>
        <h6>Xóa chuyến đi này?</h6>
        <p>Chuyến đi sẽ bị xóa hoàn toàn khỏi hệ thống và không thể khôi phục.</p>
        <form asp-action="XoaChuyenDi" asp-controller="Home" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="IdChuyenDi" value="@Model.IdChuyenDi" />
            <button type="submit" class="btn-confirm-yes">
                <i class="bi bi-trash3 me-2"></i>Xóa chuyến đi
            </button>
        </form>
        <button type="button" class="btn-confirm-no" onclick="hideConfirm()">Không, giữ lại</button>
    </div>
</div>

@section Scripts {
<script>
    function onMapLoaded() {
        document.getElementById('mapSkeleton').style.display = 'none';
        document.getElementById('mapImg').style.display = 'block';
    }
    function onMapError() {
        document.getElementById('mapWrap').innerHTML = `
            <div class="no-coords-box">
                <i class="bi bi-exclamation-triangle-fill" style="font-size:2rem;color:#fbbf24;"></i>
                <div class="fw-semibold text-dark">Không tải được bản đồ</div>
                <div style="font-size:.82rem;color:#9ca3af;">Kiểm tra kết nối hoặc API key.</div>
            </div>`;
    }
    function showConfirm() {
        document.getElementById('confirmOverlay').classList.add('show');
        document.body.style.overflow = 'hidden';
    }
    function hideConfirm(e) {
        if (!e || e.target === document.getElementById('confirmOverlay')) {
            document.getElementById('confirmOverlay').classList.remove('show');
            document.body.style.overflow = '';
        }
    }
</script>
}
