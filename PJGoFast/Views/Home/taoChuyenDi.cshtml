@using PJGoFast.Models.Enums
@using PJGoFast.ViewModels
@model ChuyenDiCreateVM

@{
    ViewData["Title"] = "Tạo Chuyến Đi Mới";
    var userAgent = Context.Request.Headers["User-Agent"].ToString().ToLower();
    
    // Nhận diện các từ khóa phổ biến của thiết bị di động
    bool isMobile = userAgent.Contains("mobi") ||
                    userAgent.Contains("android") ||
                    userAgent.Contains("iphone");

    // Chọn layout tương ứng
    if (isMobile)
    {
        Layout = "_LayoutMobile"; // Dùng cho điện thoại
    }
    else
    {
        Layout = "_Layout";       // Dùng cho máy tính (Desktop)
    }
}

<style>
    /* -------------------------------------
       1. STYLE MƯỢN TỪ CREATE.CSHTML
       ------------------------------------- */
    .card-header-custom {
        background: linear-gradient(160deg, #1d4ed8 0%, #3b82f6 60%, #60a5fa 100%);
        border-radius: 24px;
        padding: 22px 24px;
        color: #fff;
        box-shadow: 0 16px 40px rgba(37, 99, 235, .16);
    }

    .card-header-custom .icon-wrap {
        width: 52px;
        height: 52px;
        border-radius: 18px;
        background: rgba(255, 255, 255, .18);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
    }

    .form-card-custom {
        background: #fff;
        border-radius: 24px;
        border: none;
        box-shadow: 0 16px 32px rgba(15, 23, 42, .06);
    }

    .form-card-custom .form-control,
    .form-card-custom .form-select,
    .form-card-custom textarea {
        border-radius: 16px;
        min-height: 48px;
        border-color: #dbe2ea;
    }

    .form-card-custom .input-group-text {
        border-radius: 16px 0 0 16px;
        background: #f8fafc;
        border-color: #dbe2ea;
    }

    .form-card-custom .input-group .form-control,
    .form-card-custom .input-group .form-select {
        border-radius: 0 16px 16px 0;
    }

    .action-row {
        display: flex;
        gap: 12px;
        justify-content: space-between;
        flex-wrap: wrap;
    }

    .action-row .btn {
        border-radius: 999px;
        padding: 11px 24px;
        font-weight: 600;
    }

    /* -------------------------------------
       2. STYLE CHO AUTOCOMPLETE (GIỮ NGUYÊN & CẢI TIẾN)
       ------------------------------------- */
    .autocomplete-wrapper {
        position: relative;
    }

    .autocomplete-dropdown {
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        z-index: 1050;
        background: #fff;
        border: 1px solid #dbe2ea;
        border-top: none;
        border-radius: 0 0 16px 16px; /* Bo góc 16px cho mượt */
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
        max-height: 260px;
        overflow-y: auto;
        display: none;
    }

    .autocomplete-dropdown.show {
        display: block;
    }

    .autocomplete-item {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        padding: 12px 16px;
        cursor: pointer;
        transition: background 0.15s;
        border-bottom: 1px solid #f1f5f9;
    }

    .autocomplete-item:last-child {
        border-bottom: none;
    }

    .autocomplete-item:hover,
    .autocomplete-item.active {
        background-color: #f0f7ff;
    }

    .autocomplete-item .place-icon {
        flex-shrink: 0;
        width: 34px;
        height: 34px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
        margin-top: 2px;
    }

    .autocomplete-item .place-text {
        flex: 1;
        min-width: 0;
    }

    .autocomplete-item .place-main {
        font-size: 0.9rem;
        font-weight: 600;
        color: #1e293b;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .autocomplete-item .place-secondary {
        font-size: 0.8rem;
        color: #64748b;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .autocomplete-loading,
    .autocomplete-empty {
        padding: 16px;
        text-align: center;
        color: #64748b;
        font-size: 0.9rem;
    }

    /* Hiệu ứng focus */
    .input-group:has(.autocomplete-input:focus) .input-group-text,
    .form-card-custom .form-control:focus,
    .form-card-custom .form-select:focus {
        border-color: #3b82f6;
        box-shadow: none;
    }
</style>

<div class="container py-4 py-md-5">
    <div class="row justify-content-center">
        <div class="col-xl-8 col-lg-9">

            <div class="card-header-custom mb-4">
                <div class="d-flex align-items-center gap-3">
                    <div class="icon-wrap">
                        <i class="bi bi-car-front-fill"></i>
                    </div>
                    <div>
                        <h1 class="h3 mb-1 fw-bold text-white">Tạo Chuyến Đi Mới</h1>
                        <p class="mb-0 text-white-50">Điền đầy đủ thông tin chi tiết về chuyến đi bên dưới.</p>
                    </div>
                </div>
            </div>

            <div class="card form-card-custom">
                <div class="card-body p-4 p-lg-5">
                    
                    @if (!string.IsNullOrEmpty(ViewBag.Error))
                    {
                        <div class="alert alert-danger alert-dismissible fade show rounded-4 shadow-sm" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>@ViewBag.Error
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }
            
                    @if (!string.IsNullOrEmpty(ViewBag.Success))
                    {
                        <div class="alert alert-success alert-dismissible fade show rounded-4 shadow-sm" role="alert">
                            <i class="bi bi-check-circle-fill me-2"></i>@ViewBag.Success
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <form asp-action="taoChuyenDi" asp-controller="Home" method="post">
                        @Html.AntiForgeryToken()
                        <input asp-for="IdKH" type="hidden" />
                        <input asp-for="ThoiGianTao" type="hidden" />

                        <div class="row g-4 mb-4">
                            <div class="col-md-6">
                                <label asp-for="DiemDon" class="form-label fw-semibold text-dark">
                                    <i class="bi bi-geo-alt text-success me-1"></i> Điểm Đón
                                    <span class="text-danger">*</span>
                                </label>
                                <div class="autocomplete-wrapper">
                                    <div class="input-group">
                                        <span class="input-group-text border-end-0">
                                            <i class="bi bi-pin-map-fill text-success"></i>
                                        </span>
                                        <input asp-for="DiemDon" id="DiemDon" class="form-control border-start-0 ps-0 autocomplete-input" placeholder="Nhập điểm đón..." autocomplete="off" />
                                    </div>
                                    <div id="DiemDon-dropdown" class="autocomplete-dropdown"></div>
                                </div>
                                <span asp-validation-for="DiemDon" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="DiemDen" class="form-label fw-semibold text-dark">
                                    <i class="bi bi-geo-alt-fill text-danger me-1"></i> Điểm Đến
                                    <span class="text-danger">*</span>
                                </label>
                                <div class="autocomplete-wrapper">
                                    <div class="input-group">
                                        <span class="input-group-text border-end-0">
                                            <i class="bi bi-pin-map-fill text-danger"></i>
                                        </span>
                                        <input asp-for="DiemDen" id="DiemDen" class="form-control border-start-0 ps-0 autocomplete-input" placeholder="Nhập điểm đến..." autocomplete="off" />
                                    </div>
                                    <div id="DiemDen-dropdown" class="autocomplete-dropdown"></div>
                                </div>
                                <span asp-validation-for="DiemDen" class="text-danger small mt-1 d-block"></span>
                            </div>
                        </div>

                        <div class="row g-4 mb-4">
                            <div class="col-md-6">
                                <label asp-for="LoaiXeYeuCau" class="form-label fw-semibold text-dark">
                                    <i class="bi bi-truck me-1 text-primary"></i> Loại Xe Yêu Cầu
                                    <span class="text-danger">*</span>
                                </label>
                                <div class="input-group">
                                    <span class="input-group-text border-end-0">
                                        <i class="bi bi-car-front text-primary"></i>
                                    </span>
                                    <select asp-for="LoaiXeYeuCau" asp-items="Html.GetEnumSelectList<LoaiXe>()" class="form-select border-start-0">
                                        <option value="">-- Chọn loại xe --</option>
                                    </select>
                                </div>
                                <span asp-validation-for="LoaiXeYeuCau" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="ThoiGianDon" class="form-label fw-semibold text-dark">
                                    <i class="bi bi-clock me-1 text-warning"></i> Thời Gian Đón
                                    <span class="text-danger">*</span>
                                </label>
                                <div class="input-group">
                                    <span class="input-group-text border-end-0">
                                        <i class="bi bi-calendar-event text-warning"></i>
                                    </span>
                                    <input asp-for="ThoiGianDon" type="datetime-local" class="form-control border-start-0 ps-0" />
                                </div>
                                <span asp-validation-for="ThoiGianDon" class="text-danger small mt-1 d-block"></span>
                            </div>
                        </div>

                        <div class="mb-5">
                            <label asp-for="GhiChu" class="form-label fw-semibold text-dark">
                                <i class="bi bi-pencil-square me-1 text-secondary"></i> Ghi Chú
                            </label>
                            <textarea asp-for="GhiChu" class="form-control p-3" rows="3" placeholder="Nhập ghi chú thêm về hành lý, yêu cầu đặc biệt..."></textarea>
                            <span asp-validation-for="GhiChu" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="action-row mt-4 pt-3 border-top border-light">
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left me-1"></i> Quay Lại
                            </a>
                            <button type="submit" class="btn btn-primary shadow-sm">
                                <i class="bi bi-send-fill me-1"></i> Tạo Chuyến Đi
                            </button>
                        </div>

                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        const GOONG_API_KEY = 'H1eRRpu0DSAzfyP9x24rHLNX7OVocfHYoxVhCvGX';
        const GOONG_API_URL = 'https://rsapi.goong.io/v2/place/autocomplete';

        // Màu icon theo loại địa điểm
        const typeColorMap = {
            'route':           { bg: '#e8f5e9', color: '#2e7d32', icon: 'bi-sign-turn-right-fill' },
            'establishment':   { bg: '#e3f2fd', color: '#1565c0', icon: 'bi-building'              },
            'point_of_interest':{ bg: '#fff3e0', color: '#e65100', icon: 'bi-star-fill'            },
            'premise':         { bg: '#f3e5f5', color: '#6a1b9a', icon: 'bi-house-door-fill'       },
            'street_address':  { bg: '#e8f5e9', color: '#2e7d32', icon: 'bi-geo-alt-fill'          },
            'default':         { bg: '#f8fafc', color: '#64748b', icon: 'bi-geo-alt-fill'          },
        };

        function getTypeStyle(types) {
            if (!types || types.length === 0) return typeColorMap['default'];
            for (const t of types) {
                if (typeColorMap[t]) return typeColorMap[t];
            }
            return typeColorMap['default'];
        }

        function initAutocomplete(inputId, dropdownId) {
            const input    = document.getElementById(inputId);
            const dropdown = document.getElementById(dropdownId);
            let debounceTimer = null;
            let activeIndex  = -1;
            let suggestions  = [];

            input.addEventListener('input', () => {
                const query = input.value.trim();
                clearTimeout(debounceTimer);
                activeIndex = -1;

                if (query.length < 2) {
                    closeDropdown();
                    return;
                }

                showLoading();
                debounceTimer = setTimeout(() => fetchSuggestions(query), 300);
            });

            input.addEventListener('keydown', (e) => {
                const items = dropdown.querySelectorAll('.autocomplete-item');
                if (!items.length) return;

                if (e.key === 'ArrowDown') {
                    e.preventDefault();
                    activeIndex = (activeIndex + 1) % items.length;
                    updateActive(items);
                } else if (e.key === 'ArrowUp') {
                    e.preventDefault();
                    activeIndex = (activeIndex - 1 + items.length) % items.length;
                    updateActive(items);
                } else if (e.key === 'Enter') {
                    e.preventDefault();
                    if (activeIndex >= 0 && suggestions[activeIndex]) {
                        selectSuggestion(suggestions[activeIndex]);
                    }
                } else if (e.key === 'Escape') {
                    closeDropdown();
                }
            });

            // Đóng dropdown khi click ra ngoài
            document.addEventListener('click', (e) => {
                if (!input.closest('.autocomplete-wrapper').contains(e.target)) {
                    closeDropdown();
                }
            });

            function updateActive(items) {
                items.forEach((el, i) => {
                    el.classList.toggle('active', i === activeIndex);
                });
            }

            async function fetchSuggestions(query) {
                try {
                    const url = `${GOONG_API_URL}?input=${encodeURIComponent(query)}&api_key=${GOONG_API_KEY}`;
                    const res  = await fetch(url);
                    const data = await res.json();
                
                    if (data.predictions && data.predictions.length > 0) {
                        suggestions = data.predictions;
                        renderDropdown(suggestions);
                    } else {
                        suggestions = [];
                        showEmpty();
                    }
                } catch (err) {
                    console.error('Goong API error:', err);
                    closeDropdown();
                }
            }

            function renderDropdown(predictions) {
                dropdown.innerHTML = '';
                predictions.forEach((place, idx) => {
                    const mainText      = place.structured_formatting?.main_text      || place.description;
                    const secondaryText = place.structured_formatting?.secondary_text || '';
                    const style         = getTypeStyle(place.types);

                    const item = document.createElement('div');
                    item.className = 'autocomplete-item';
                    item.dataset.index = idx;
                    item.innerHTML = `
                        <div class="place-icon" style="background:${style.bg}; color:${style.color}">
                            <i class="bi ${style.icon}"></i>
                        </div>
                        <div class="place-text">
                            <div class="place-main">${escapeHtml(mainText)}</div>
                            ${secondaryText ? `<div class="place-secondary">${escapeHtml(secondaryText)}</div>` : ''}
                        </div>`;

                    item.addEventListener('mousedown', (e) => {
                        e.preventDefault(); // Tránh blur input trước khi chọn
                        selectSuggestion(place);
                    });

                    item.addEventListener('mouseover', () => {
                        activeIndex = idx;
                        updateActive(dropdown.querySelectorAll('.autocomplete-item'));
                    });
                
                    dropdown.appendChild(item);
                });
                openDropdown();
            }

            function selectSuggestion(place) {
                input.value = place.description;
                closeDropdown();
                input.dispatchEvent(new Event('change'));
            }

            function showLoading() {
                dropdown.innerHTML = `<div class="autocomplete-loading"><span class="spinner-border spinner-border-sm me-2" role="status"></span>Đang tìm kiếm...</div>`;
                openDropdown();
            }

            function showEmpty() {
                dropdown.innerHTML = `<div class="autocomplete-empty"><i class="bi bi-search me-2"></i>Không tìm thấy địa điểm phù hợp</div>`;
                openDropdown();
            }

            function openDropdown() {
                dropdown.classList.add('show');
                // Gỡ bỏ góc bo tròn phía dưới khi dropdown hiện để tạo cảm giác liền mạch
                input.style.borderBottomRightRadius = '0';
                input.closest('.input-group').querySelector('.input-group-text').style.borderBottomLeftRadius = '0';
            }

            function closeDropdown() {
                dropdown.classList.remove('show');
                activeIndex = -1;
                // Trả lại bo góc 16px
                input.style.borderBottomRightRadius = '16px';
                input.closest('.input-group').querySelector('.input-group-text').style.borderBottomLeftRadius = '16px';
            }
        }

        function escapeHtml(text) {
            const d = document.createElement('div');
            d.appendChild(document.createTextNode(text));
            return d.innerHTML;
        }

        // Khởi tạo cho cả 2 ô nhập
        initAutocomplete('DiemDon', 'DiemDon-dropdown');
        initAutocomplete('DiemDen', 'DiemDen-dropdown');
    </script>
}