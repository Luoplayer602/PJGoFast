@using PJGoFast.Models.Entities
@using PJGoFast.Models.Enums
@model ChuyenDi

@{
    ViewData["Title"] = "Chi tiết chuyến đi";
    var userAgent = Context.Request.Headers["User-Agent"].ToString().ToLower();
    var isMobile = userAgent.Contains("mobi") || userAgent.Contains("android") || userAgent.Contains("iphone");
    Layout = isMobile ? "_LayoutMobile" : "_Layout";

    var coTheHuy = Model.TrangThai == TrangThaiChuyen.CHO || Model.TrangThai == TrangThaiChuyen.MOI || Model.TrangThai == TrangThaiChuyen.DA_PHAN_CONG;
    var statusText = Model.TrangThai switch
    {
        TrangThaiChuyen.CHO => "Đang xem báo giá",
        TrangThaiChuyen.MOI => "Chờ phân công",
        TrangThaiChuyen.DA_PHAN_CONG => "Đã phân công",
        TrangThaiChuyen.DA_NHAN => "Tài xế đã nhận",
        TrangThaiChuyen.DANG_DON => "Đang đón",
        TrangThaiChuyen.DA_DON => "Đã đón",
        TrangThaiChuyen.DANG_DI_CHUYEN => "Đang di chuyển",
        TrangThaiChuyen.HOAN_TAT => "Hoàn tất",
        TrangThaiChuyen.HUY => "Đã hủy",
        _ => Model.TrangThai.ToString()
    };
}

<style>
    .trip-detail-page {
        display: grid;
        grid-template-columns: minmax(0, 1.3fr) minmax(300px, .9fr);
        gap: 18px;
    }

    .trip-card {
        background: #fff;
        border-radius: 24px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 10px 28px rgba(15,23,42,.06);
        overflow: hidden;
    }

    .trip-hero {
        padding: 24px;
        color: #fff;
        background: linear-gradient(160deg, #0f172a, #1d4ed8 72%, #60a5fa);
    }

    .trip-hero h1 {
        margin: 0 0 8px;
        font-size: 1.5rem;
        font-weight: 800;
    }

    .hero-chip {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 12px;
        border-radius: 999px;
        background: rgba(255,255,255,.14);
        border: 1px solid rgba(255,255,255,.18);
        font-size: .8rem;
        font-weight: 700;
        margin: 12px 8px 0 0;
    }

    .trip-body {
        padding: 22px 24px;
        display: grid;
        gap: 18px;
    }

    .info-block {
        background: #f8fbff;
        border: 1px solid #e2e8f0;
        border-radius: 20px;
        padding: 18px;
    }

    .info-block h2 {
        margin: 0 0 12px;
        font-size: .84rem;
        text-transform: uppercase;
        letter-spacing: .06em;
        color: #64748b;
        font-weight: 800;
    }

    .info-item + .info-item {
        margin-top: 10px;
    }

    .info-item small {
        display: block;
        color: #94a3b8;
        margin-bottom: 3px;
    }

    .info-item strong {
        display: block;
        line-height: 1.45;
        color: #0f172a;
    }

    .action-stack {
        display: grid;
        gap: 10px;
    }

    .action-stack .btn {
        border-radius: 16px;
        padding: 12px 16px;
        font-weight: 800;
    }

    @@media (max-width: 992px) {
        .trip-detail-page {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="trip-detail-page">
    <section class="trip-card">
        <div class="trip-hero">
            <h1>Chuyến @Model.IdChuyenDi</h1>
            <div>Thông tin trạng thái, lộ trình và người phụ trách của chuyến đi.</div>
            <div>
                <span class="hero-chip"><i class="bi bi-flag"></i>@statusText</span>
                <span class="hero-chip"><i class="bi bi-clock"></i>@Model.ThoiGianDon.ToString("HH:mm dd/MM/yyyy")</span>
                <span class="hero-chip"><i class="bi bi-cash-stack"></i>@(Model.GiaTamTinh?.ToString("N0") ?? "0") đ</span>
            </div>
        </div>

        <div class="trip-body">
            <div class="info-block">
                <h2>Lộ trình</h2>
                <div class="info-item"><small>Điểm đón</small><strong>@Model.DiemDon</strong></div>
                <div class="info-item"><small>Điểm đến</small><strong>@Model.DiemDen</strong></div>
                <div class="info-item"><small>Ghi chú</small><strong>@(string.IsNullOrWhiteSpace(Model.GhiChu) ? "Không có" : Model.GhiChu)</strong></div>
            </div>

            <div class="info-block">
                <h2>Người phụ trách</h2>
                <div class="info-item"><small>Tài xế</small><strong>@(Model.TaiXe != null ? $"{Model.TaiXe.HoVaTen} · {Model.TaiXe.SDT}" : "Chưa có tài xế")</strong></div>
                <div class="info-item"><small>Điều phối</small><strong>@(Model.Admin != null ? $"{Model.Admin.HoVaTen} · {Model.Admin.SDT}" : "Chưa có điều phối")</strong></div>
            </div>
        </div>
    </section>

    <section class="trip-card">
        <div class="trip-body">
            <div class="info-block">
                <h2>Thao tác</h2>
                <div class="action-stack">
                    <a asp-action="TheoDoiChuyenDi" asp-route-IdChuyenDi="@Model.IdChuyenDi" class="btn btn-primary">
                        <i class="bi bi-broadcast-pin me-1"></i> Xem tiến trình & nhật ký
                    </a>
                    <a asp-action="History" class="btn btn-light border">
                        <i class="bi bi-arrow-left me-1"></i> Quay lại lịch sử
                    </a>
                    @if (coTheHuy)
                    {
                        <button type="button" class="btn btn-outline-danger" onclick="confirmCancel()">
                            <i class="bi bi-x-circle me-1"></i> Hủy chuyến
                        </button>
                    }
                </div>
            </div>
        </div>
    </section>
</div>

@if (coTheHuy)
{
    <form id="cancelTripForm" asp-action="HuyChuyenDi" method="post" class="d-none">
        @Html.AntiForgeryToken()
        <input type="hidden" name="IdChuyenDi" value="@Model.IdChuyenDi" />
    </form>

    @section Scripts {
    <script>
        function confirmCancel() {
            if (confirm('Xác nhận hủy chuyến này?')) {
                document.getElementById('cancelTripForm').submit();
            }
        }
    </script>
    }
}
