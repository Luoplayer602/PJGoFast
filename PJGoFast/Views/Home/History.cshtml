@model List<PJGoFast.ViewModels.ChuyenDiHistoryItemVM>

@{
    ViewData["Title"] = "Lịch sử chuyến đi";
}

<div class="container py-4">
    <h1 class="h3 mb-3">Lịch sử chuyến đi</h1>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info mb-0">Bạn chưa có chuyến đi nào.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <thead>
                    <tr>
                        <th>Mã chuyến</th>
                        <th>Điểm đón</th>
                        <th>Điểm đến</th>
                        <th>Loại xe</th>
                        <th>Trạng thái</th>
                        <th>Thời gian tạo</th>
                        <th>Thời gian đón</th>
                        <th>Giá tạm tính</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.IdChuyenDi</td>
                            <td>@item.DiemDon</td>
                            <td>@item.DiemDen</td>
                            <td>@item.LoaiXeYeuCau</td>
                            <td>@item.TrangThai</td>
                            <td>@item.ThoiGianTao.ToString("HH:mm dd/MM/yyyy")</td>
                            <td>@item.ThoiGianDon.ToString("HH:mm dd/MM/yyyy")</td>
                            <td>@(item.GiaTamTinh.HasValue ? string.Format("{0:N0} đ", item.GiaTamTinh.Value) : "-")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
