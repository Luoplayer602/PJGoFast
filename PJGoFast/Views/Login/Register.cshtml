@{
}
<div>
    @if (!string.IsNullOrEmpty(ViewBag.Error))
    {
        <div class="alert alert-danger">@ViewBag.Error</div>
    }
    <form asp-action="Register" asp-controller="Login" method="post">
        <div class="form-floating mb-4">
            <input class="form-control" id="sdt" name="sdt" type="text" placeholder="Nhập số điện thoại..." required />
            <label for="sdt">Số điện thoại</label>
        </div>

        <div class="form-floating mb-4">
            <input class="form-control" id="matKhau" name="matKhau" type="password" placeholder="Nhập mật khẩu..." required />
            <label for="matKhau">Mật khẩu</label>
        </div>

        <div class="form-floating mb-4">
            <input class="form-control" id="confirmMatKhau" name="confirmMatKhau" type="password" placeholder="Xác nhận mật khẩu..." required />
        </div>

        <div class="d-grid mt-4 mb-0">
            <button class="btn btn-primary btn-block" type="submit">Đăng ký</button>
        </div>
        
    </form>
</div>
