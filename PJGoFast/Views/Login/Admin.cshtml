@{
    Layout = "_ImportBootstrap";
    ViewData["Title"] = "Đăng nhập";
}

<style>
    body {
        background-color: #f8f9fa;
    }
</style>

<div class="container d-flex flex-column justify-content-center min-vh-100">
    <div class="row justify-content-center">
        <div class="col-xl-5 col-lg-6 col-md-8 col-sm-10">
            <div class="card shadow-lg border-0 rounded-lg mt-5 mb-5">
                
                <div class="card-header bg-primary text-white text-center py-4">
                    <h3 class="font-weight-light my-1">Đăng nhập - Admin</h3>
                </div>

                <div class="card-body p-4 p-md-5">
                    
                    @if (!string.IsNullOrEmpty(ViewBag.Error))
                    {
                        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
                            @ViewBag.Error
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <form asp-action="Admin" asp-controller="Login" method="post">
                        <div class="form-floating mb-4">
                            <input class="form-control rounded-3" id="sdt" name="sdt" type="text" placeholder="Nhập số điện thoại..." required />
                            <label for="sdt" class="text-muted">Số điện thoại</label>
                        </div>

                        <div class="form-floating mb-4">
                            <input class="form-control rounded-3" id="matKhau" name="matKhau" type="password" placeholder="Nhập mật khẩu..." required />
                            <label for="matKhau" class="text-muted">Mật khẩu</label>
                        </div>

                        <div class="d-grid mt-4 mb-3">
                            <button class="btn btn-primary btn-lg rounded-3 shadow-sm py-2" type="submit">
                                Đăng nhập
                            </button>
                        </div>
                    </form>
                </div>
                
                

            </div>
        </div>
    </div>
</div>