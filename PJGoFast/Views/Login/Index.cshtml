@{
    ViewData["Title"] = "Đăng nhập";
}

<section class="auth-wrap">
    <div class="auth-card">
        <h1 class="auth-title mb-2">Chào mừng quay lại 👋</h1>
        <p class="auth-subtitle">Đăng nhập để đặt xe nhanh chóng và theo dõi chuyến đi của bạn.</p>

        @if (!string.IsNullOrEmpty(ViewBag.Error))
        {
            <div class="alert alert-danger" role="alert">@ViewBag.Error</div>
        }

        <form asp-action="Index" asp-controller="Login" method="post" class="d-grid gap-3">
            @Html.AntiForgeryToken()
            <div class="form-floating">
                <input class="form-control" id="sdt" name="sdt" type="tel" placeholder="Nhập số điện thoại..." autocomplete="tel" required />
                <label for="sdt">Số điện thoại</label>
            </div>

            <div class="form-floating">
                <input class="form-control" id="matKhau" name="matKhau" type="password" placeholder="Nhập mật khẩu..." autocomplete="current-password" required />
                <label for="matKhau">Mật khẩu</label>
            </div>

            <button class="btn btn-brand btn-lg w-100" type="submit">Đăng nhập</button>
        </form>

        <p class="auth-link mt-3 mb-0 text-center">
            Chưa có tài khoản?
            <a asp-controller="Login" asp-action="Register">Đăng ký ngay</a>
        </p>
    </div>
</section>
