@model AdminDetailsVM

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Chi tiết admin";
    var initials = string.IsNullOrWhiteSpace(Model.HoVaTen)
        ? "?"
        : string.Join("", Model.HoVaTen.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .TakeLast(2)
            .Select(part => part[0].ToString().ToUpper()));
}

<style>
    .account-hero {
        background: linear-gradient(160deg, #1d4ed8 0%, #3b82f6 60%, #60a5fa 100%);
        padding: 34px 24px 76px;
        text-align: center;
        border-radius: 28px;
        position: relative;
        box-shadow: 0 18px 40px rgba(37, 99, 235, .18);
    }

    .avatar-circle {
        width: 92px;
        height: 92px;
        border-radius: 50%;
        background: rgba(255, 255, 255, .22);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        font-weight: 800;
        color: #fff;
        margin: 0 auto 14px;
        border: 3px solid rgba(255, 255, 255, .38);
    }

    .account-hero .name {
        font-size: 1.25rem;
        font-weight: 800;
        color: #fff;
        margin-bottom: 4px;
    }

    .account-hero .role-tag {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: rgba(255, 255, 255, .2);
        color: #fff;
        border-radius: 999px;
        padding: 5px 16px;
        font-size: .78rem;
        font-weight: 700;
    }

    .member-chip {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: rgba(255, 255, 255, .15);
        border-radius: 999px;
        padding: 5px 14px;
        font-size: .76rem;
        color: rgba(255, 255, 255, .88);
        margin-top: 10px;
    }

    .info-overlap {
        margin: -44px auto 0;
        max-width: 860px;
        background: #fff;
        border-radius: 24px;
        box-shadow: 0 16px 32px rgba(15, 23, 42, .08);
        overflow: hidden;
    }

    .info-row {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 16px 20px;
        border-bottom: 1px solid #f1f5f9;
    }

    .info-row:last-child {
        border-bottom: none;
    }

    .info-icon {
        width: 42px;
        height: 42px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        flex-shrink: 0;
    }

    .ilabel {
        font-size: .74rem;
        color: #94a3b8;
        margin-bottom: 2px;
        text-transform: uppercase;
        letter-spacing: .04em;
        font-weight: 700;
    }

    .ival {
        font-size: .97rem;
        font-weight: 700;
        color: #111827;
    }

    .actions-wrap {
        max-width: 860px;
        margin: 16px auto 0;
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 12px;
    }

    .actions-wrap .btn {
        border-radius: 16px;
        padding: 13px 16px;
        font-weight: 800;
    }

    .confirm-overlay {
        position: fixed;
        inset: 0;
        display: none;
        align-items: flex-end;
        justify-content: center;
        background: rgba(15, 23, 42, .45);
        z-index: 500;
    }

    .confirm-overlay.show {
        display: flex;
    }

    .confirm-sheet {
        width: 100%;
        max-width: 520px;
        background: #fff;
        border-radius: 26px 26px 0 0;
        padding: 28px 24px 24px;
        box-shadow: 0 -16px 32px rgba(15, 23, 42, .14);
    }

    .confirm-sheet .icon-wrap {
        width: 58px;
        height: 58px;
        border-radius: 50%;
        background: #fef2f2;
        color: #dc2626;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        margin: 0 auto 14px;
    }

    .confirm-sheet h5 {
        text-align: center;
        font-weight: 800;
        margin-bottom: 8px;
    }

    .confirm-sheet p {
        text-align: center;
        color: #64748b;
        margin-bottom: 18px;
    }

    .confirm-actions {
        display: grid;
        gap: 10px;
    }

    .confirm-actions .btn {
        border-radius: 16px;
        padding: 13px;
        font-weight: 800;
    }

    @@media (max-width: 768px) {
        .actions-wrap {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="account-hero">
    <div class="avatar-circle">@initials</div>
    <div class="name">@Model.HoVaTen</div>
    <span class="role-tag">
        <i class="bi bi-shield-check"></i>@Model.VaiTro
    </span>
    <div class="member-chip">
        <i class="bi bi-hash"></i>@Model.IdAdmin
    </div>
</div>

<div class="info-overlap">
    <div class="info-row">
        <div class="info-icon" style="background:#eff6ff;color:#2563eb;">
            <i class="bi bi-person-vcard-fill"></i>
        </div>
        <div>
            <div class="ilabel">Id admin</div>
            <div class="ival" style="font-family:Consolas, monospace;">@Model.IdAdmin</div>
        </div>
    </div>
    <div class="info-row">
        <div class="info-icon" style="background:#f0fdf4;color:#16a34a;">
            <i class="bi bi-person-fill"></i>
        </div>
        <div>
            <div class="ilabel">Họ và tên</div>
            <div class="ival">@Model.HoVaTen</div>
        </div>
    </div>
    <div class="info-row">
        <div class="info-icon" style="background:#fff7ed;color:#ea580c;">
            <i class="bi bi-telephone-fill"></i>
        </div>
        <div>
            <div class="ilabel">Số điện thoại</div>
            <div class="ival">@Model.SDT</div>
        </div>
    </div>
    <div class="info-row">
        <div class="info-icon" style="background:#fdf4ff;color:#9333ea;">
            <i class="bi bi-calendar-event-fill"></i>
        </div>
        <div>
            <div class="ilabel">Ngày sinh</div>
            <div class="ival">@(Model.NgaySinh?.ToString("dd/MM/yyyy") ?? "Chưa cập nhật")</div>
        </div>
    </div>
    <div class="info-row">
        <div class="info-icon" style="background:#eef2ff;color:#4f46e5;">
            <i class="bi bi-shield-lock-fill"></i>
        </div>
        <div>
            <div class="ilabel">Vai trò</div>
            <div class="ival">@Model.VaiTro</div>
        </div>
    </div>
</div>

<div class="actions-wrap">
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i> Quay lại danh sách
    </a>
    <a asp-action="Edit" asp-route-id="@Model.IdAdmin" class="btn btn-primary">
        <i class="bi bi-pencil-square me-1"></i> Sửa thông tin
    </a>
    <button type="button" class="btn btn-outline-danger" onclick="showDeleteConfirm()">
        <i class="bi bi-trash3-fill me-1"></i> Xóa admin
    </button>
</div>

<div class="confirm-overlay" id="deleteConfirmOverlay" onclick="hideDeleteConfirm(event)">
    <div class="confirm-sheet" onclick="event.stopPropagation()">
        <div class="icon-wrap">
            <i class="bi bi-exclamation-triangle-fill"></i>
        </div>
        <h5>Xác nhận xóa admin?</h5>
        <p>Thao tác này sẽ xóa tài khoản <strong>@Model.HoVaTen</strong> khỏi danh sách quản lý. Hệ thống sẽ yêu cầu xác nhận bằng nút bên dưới.</p>
        <div class="confirm-actions">
            <form asp-action="Delete" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.IdAdmin" />
                <button type="submit" class="btn btn-danger w-100">
                    <i class="bi bi-trash3-fill me-1"></i> Xác nhận xóa
                </button>
            </form>
            <button type="button" class="btn btn-light border" onclick="hideDeleteConfirm()">
                Giữ lại tài khoản
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function showDeleteConfirm() {
            document.getElementById('deleteConfirmOverlay').classList.add('show');
            document.body.style.overflow = 'hidden';
        }

        function hideDeleteConfirm(event) {
            const overlay = document.getElementById('deleteConfirmOverlay');
            if (!event || event.target === overlay) {
                overlay.classList.remove('show');
                document.body.style.overflow = '';
            }
        }
    </script>
}
