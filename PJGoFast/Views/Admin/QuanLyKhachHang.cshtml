@using PJGoFast.Models.Entities
@model List<KhachHang>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản lý Khách hàng";
}

<style>
    .page-hero {
        background: linear-gradient(160deg, #9333ea 0%, #a855f7 60%, #d946ef 100%);
        color: #fff;
        border-radius: 28px;
        padding: 28px 24px;
        box-shadow: 0 16px 40px rgba(147, 51, 234, .18);
        margin-bottom: 18px;
    }

    .page-hero h1 {
        font-size: clamp(1.5rem, 2vw, 2rem);
        font-weight: 800;
        margin-bottom: 8px;
    }

    .page-hero p {
        margin: 0;
        max-width: 680px;
        color: rgba(255, 255, 255, .86);
    }

    .customers-wrapper {
        background: #fff;
        border-radius: 24px;
        box-shadow: 0 10px 28px rgba(15, 23, 42, .06);
        border: 1px solid #e2e8f0;
        overflow: hidden;
    }

    .desktop-view {
        display: block;
    }

    .mobile-view {
        display: none;
    }

    .table-wrapper {
        overflow-x: auto;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        font-size: .9rem;
    }

    thead {
        background: #f8fafc;
        border-bottom: 2px solid #e2e8f0;
    }

    th {
        padding: 14px 16px;
        text-align: left;
        font-weight: 800;
        color: #475569;
        text-transform: uppercase;
        letter-spacing: .05em;
        font-size: .75rem;
    }

    td {
        padding: 14px 16px;
        border-bottom: 1px solid #f1f5f9;
        color: #0f172a;
    }

    tbody tr:hover {
        background: #f8fafc;
    }

    tbody tr:last-child td {
        border-bottom: none;
    }

    .customer-name {
        font-weight: 700;
        color: #111827;
    }

    .customer-phone {
        color: #6b7280;
        font-size: .85rem;
    }

    .status-chip {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 5px 10px;
        border-radius: 999px;
        font-size: .75rem;
        font-weight: 700;
        background: #dcfce7;
        color: #166534;
    }

    .trips-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
        background: #eff6ff;
        color: #2563eb;
        border-radius: 10px;
        font-weight: 700;
        font-size: .9rem;
    }

    .date-text {
        color: #6b7280;
        font-size: .85rem;
    }

    .empty-state {
        text-align: center;
        padding: 60px 20px;
        color: #6b7280;
    }

    .empty-state-icon {
        font-size: 3.5rem;
        color: #d1d5db;
        margin-bottom: 12px;
    }

    .empty-state h2 {
        font-size: 1.25rem;
        font-weight: 700;
        color: #1f2937;
        margin: 0 0 8px;
    }

    .empty-state p {
        margin: 0;
        font-size: .95rem;
    }

    /* Mobile Cards */
    .customer-card {
        display: none;
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        padding: 16px;
        margin-bottom: 12px;
        gap: 12px;
    }

    .card-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 8px 0;
        border-bottom: 1px solid #f1f5f9;
    }

    .card-row:last-child {
        border-bottom: none;
    }

    .card-label {
        font-weight: 700;
        color: #475569;
        font-size: .8rem;
        text-transform: uppercase;
        letter-spacing: .05em;
    }

    .card-value {
        color: #0f172a;
        font-weight: 600;
        text-align: right;
    }

    @@media (max-width: 768px) {
        .desktop-view {
            display: none;
        }

        .mobile-view {
            display: block;
        }

        .customer-card {
            display: grid;
        }

        .customers-wrapper {
            padding: 12px;
        }
    }
</style>

<div class="page-hero">
    <h1><i class="bi bi-people-fill me-2"></i>Quản lý Khách hàng</h1>
    <p>Xem thông tin, lịch sử giao dịch và hỗ trợ tài khoản khách hàng trong hệ thống.</p>
</div>

@if (Model != null && Model.Any())
{
    <div class="customers-wrapper">
        <!-- Desktop Table View -->
        <div class="desktop-view">
            <div class="table-wrapper">
                <table>
                    <thead>
                        <tr>
                            <th>Khách hàng</th>
                            <th>Số điện thoại</th>
                            <th>Email</th>
                            <th>Ngày sinh</th>
                            <th>Ngày đăng ký</th>
                            <th>Tổng chuyến</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var customer in Model.OrderByDescending(k => k.NgayDangKy))
                        {
                            var tripCount = customer.ChuyenDis?.Count ?? 0;

                            <tr>
                                <td>
                                    <div class="customer-name">@customer.HoVaTen</div>
                                </td>
                                <td>
                                    <div class="customer-phone">@customer.SDT</div>
                                </td>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(customer.Email))
                                    {
                                        <span>@customer.Email</span>
                                    }
                                    else
                                    {
                                        <span style="color: #d1d5db;">-</span>
                                    }
                                </td>
                                <td>
                                    @if (customer.NgaySinh.HasValue)
                                    {
                                        <span class="date-text">@customer.NgaySinh.Value.ToString("dd/MM/yyyy")</span>
                                    }
                                    else
                                    {
                                        <span style="color: #d1d5db;">-</span>
                                    }
                                </td>
                                <td>
                                    <span class="date-text">@customer.NgayDangKy.ToString("dd/MM/yyyy")</span>
                                </td>
                                <td>
                                    <div class="trips-badge">@tripCount</div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Mobile Card View -->
        <div class="mobile-view">
            @foreach (var customer in Model.OrderByDescending(k => k.NgayDangKy))
            {
                var tripCount = customer.ChuyenDis?.Count ?? 0;

                <div class="customer-card">
                    <div class="card-row">
                        <span class="card-label">Tên khách hàng</span>
                        <span class="card-value">@customer.HoVaTen</span>
                    </div>
                    <div class="card-row">
                        <span class="card-label">Số điện thoại</span>
                        <span class="card-value">@customer.SDT</span>
                    </div>
                    <div class="card-row">
                        <span class="card-label">Email</span>
                        <span class="card-value">
                            @if (!string.IsNullOrWhiteSpace(customer.Email))
                            {
                                @customer.Email
                            }
                            else
                            {
                                <span style="color: #d1d5db;">-</span>
                            }
                        </span>
                    </div>
                    <div class="card-row">
                        <span class="card-label">Ngày đăng ký</span>
                        <span class="card-value">@customer.NgayDangKy.ToString("dd/MM/yyyy")</span>
                    </div>
                    <div class="card-row">
                        <span class="card-label">Tổng chuyến</span>
                        <span class="card-value">@tripCount</span>
                    </div>
                </div>
            }
        </div>
    </div>
}
else
{
    <div class="empty-state">
        <div class="empty-state-icon">
            <i class="bi bi-inbox"></i>
        </div>
        <h2>Chưa có khách hàng nào</h2>
        <p>Hiện tại không có dữ liệu khách hàng trong hệ thống.</p>
    </div>
}
