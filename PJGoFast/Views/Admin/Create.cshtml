@model AdminCreateVM

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Thêm admin";
}

<style>
    .card-header-custom {
        background: linear-gradient(160deg, #1d4ed8 0%, #3b82f6 60%, #60a5fa 100%);
        border-radius: 24px;
        padding: 22px 24px;
        color: #fff;
        box-shadow: 0 16px 40px rgba(37, 99, 235, .16);
    }

    .card-header-custom .icon-wrap {
        width: 52px;
        height: 52px;
        border-radius: 18px;
        background: rgba(255, 255, 255, .18);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
    }

    .admin-form-card {
        background: #fff;
        border-radius: 24px;
        border: none;
        box-shadow: 0 16px 32px rgba(15, 23, 42, .06);
    }

    .admin-form-card .form-control,
    .admin-form-card .form-select {
        border-radius: 16px;
        min-height: 48px;
        border-color: #dbe2ea;
    }

    .admin-form-card .input-group-text {
        border-radius: 16px 0 0 16px;
        background: #f8fafc;
        border-color: #dbe2ea;
    }

    .admin-form-card .input-group .form-control,
    .admin-form-card .input-group .form-select {
        border-radius: 0 16px 16px 0;
    }

    .action-row {
        display: flex;
        gap: 12px;
        justify-content: space-between;
        flex-wrap: wrap;
    }

    .action-row .btn {
        border-radius: 999px;
        padding: 11px 18px;
        font-weight: 700;
    }
</style>

<div class="row justify-content-center">
    <div class="col-xl-8 col-lg-9">
        <div class="card-header-custom mb-4">
            <div class="d-flex align-items-center gap-3">
                <div class="icon-wrap">
                    <i class="bi bi-person-plus-fill"></i>
                </div>
                <div>
                    <h1 class="h3 mb-1 fw-bold">Thêm admin mới</h1>
                    <p class="mb-0 text-white-50">Tạo tài khoản quản trị hoặc điều phối mới với thông tin cơ bản và mật khẩu ban đầu.</p>
                </div>
            </div>
        </div>

        <div class="card admin-form-card">
            <div class="card-body p-4 p-lg-5">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-4 mb-4"></div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="IdAdmin" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-hash text-primary"></i></span>
                                <input asp-for="IdAdmin" class="form-control" placeholder="Ví dụ: ADMIN001" />
                            </div>
                            <span asp-validation-for="IdAdmin" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="VaiTro" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-shield-check text-primary"></i></span>
                                <select asp-for="VaiTro" class="form-select">
                                    @foreach (var role in AdminRoleOptions.All)
                                    {
                                        <option value="@role">@role</option>
                                    }
                                </select>
                            </div>
                            <span asp-validation-for="VaiTro" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="HoVaTen" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-person-fill text-primary"></i></span>
                                <input asp-for="HoVaTen" class="form-control" placeholder="Nhập họ và tên" />
                            </div>
                            <span asp-validation-for="HoVaTen" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="SDT" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-telephone-fill text-primary"></i></span>
                                <input asp-for="SDT" class="form-control" placeholder="Nhập số điện thoại" />
                            </div>
                            <span asp-validation-for="SDT" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="NgaySinh" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-calendar-event text-primary"></i></span>
                            <input asp-for="NgaySinh" type="date" class="form-control" />
                        </div>
                        <span asp-validation-for="NgaySinh" class="text-danger small"></span>
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label asp-for="MatKhau" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-key-fill text-primary"></i></span>
                                <input asp-for="MatKhau" class="form-control" placeholder="Tối thiểu 6 ký tự" />
                            </div>
                            <span asp-validation-for="MatKhau" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="XacNhanMatKhau" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-shield-lock-fill text-primary"></i></span>
                                <input asp-for="XacNhanMatKhau" class="form-control" placeholder="Nhập lại mật khẩu" />
                            </div>
                            <span asp-validation-for="XacNhanMatKhau" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="action-row">
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-1"></i> Quay lại danh sách
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check2-circle me-1"></i> Tạo admin
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
