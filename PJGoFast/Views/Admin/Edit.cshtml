@model AdminEditVM

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Sửa admin";
}

<style>
    .card-header-custom {
        background: linear-gradient(160deg, #1d4ed8 0%, #3b82f6 60%, #60a5fa 100%);
        border-radius: 24px;
        padding: 22px 24px;
        color: #fff;
        box-shadow: 0 16px 40px rgba(37, 99, 235, .16);
    }

    .card-header-custom .icon-wrap {
        width: 52px;
        height: 52px;
        border-radius: 18px;
        background: rgba(255, 255, 255, .18);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
    }

    .admin-form-card {
        background: #fff;
        border-radius: 24px;
        border: none;
        box-shadow: 0 16px 32px rgba(15, 23, 42, .06);
    }

    .admin-form-card .form-control,
    .admin-form-card .form-select {
        border-radius: 16px;
        min-height: 48px;
        border-color: #dbe2ea;
    }

    .admin-form-card .input-group-text {
        border-radius: 16px 0 0 16px;
        background: #f8fafc;
        border-color: #dbe2ea;
    }

    .admin-form-card .input-group .form-control,
    .admin-form-card .input-group .form-select {
        border-radius: 0 16px 16px 0;
    }

    .reset-card {
        background: linear-gradient(135deg, #eff6ff, #f8fafc);
        border: 1px solid #bfdbfe;
        border-radius: 20px;
        padding: 18px;
        margin-top: 8px;
    }

    .reset-card .btn {
        border-radius: 999px;
        font-weight: 800;
    }

    .password-panel {
        display: none;
        margin-top: 16px;
    }

    .password-panel.show {
        display: block;
    }

    .action-row {
        display: flex;
        gap: 12px;
        justify-content: space-between;
        flex-wrap: wrap;
    }

    .action-row .btn {
        border-radius: 999px;
        padding: 11px 18px;
        font-weight: 700;
    }
</style>

<div class="row justify-content-center">
    <div class="col-xl-8 col-lg-9">
        <div class="card-header-custom mb-4">
            <div class="d-flex align-items-center gap-3">
                <div class="icon-wrap">
                    <i class="bi bi-pencil-square"></i>
                </div>
                <div>
                    <h1 class="h3 mb-1 fw-bold">Chỉnh sửa admin</h1>
                    <p class="mb-0 text-white-50">Cập nhật thông tin liên hệ, vai trò và đặt lại mật khẩu khi cần.</p>
                </div>
            </div>
        </div>

        <div class="card admin-form-card">
            <div class="card-body p-4 p-lg-5">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="IdAdmin" type="hidden" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-4 mb-4"></div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Mã admin</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-hash text-primary"></i></span>
                            <input value="@Model.IdAdmin" class="form-control" readonly />
                        </div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="HoVaTen" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-person-fill text-primary"></i></span>
                                <input asp-for="HoVaTen" class="form-control" placeholder="Nhập họ và tên" />
                            </div>
                            <span asp-validation-for="HoVaTen" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="SDT" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-telephone-fill text-primary"></i></span>
                                <input asp-for="SDT" class="form-control" placeholder="Nhập số điện thoại" />
                            </div>
                            <span asp-validation-for="SDT" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label asp-for="NgaySinh" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-calendar-event text-primary"></i></span>
                                <input asp-for="NgaySinh" type="date" class="form-control" />
                            </div>
                            <span asp-validation-for="NgaySinh" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="VaiTro" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-shield-check text-primary"></i></span>
                                <select asp-for="VaiTro" class="form-select">
                                    @foreach (var role in AdminRoleOptions.All)
                                    {
                                        <option value="@role">@role</option>
                                    }
                                </select>
                            </div>
                            <span asp-validation-for="VaiTro" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="reset-card">
                        <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
                            <div>
                                <div class="fw-bold text-dark">Đặt lại mật khẩu</div>
                                <div class="text-muted small">Nhấn nút bên phải để mở các trường nhập mật khẩu mới và xác nhận mật khẩu.</div>
                            </div>
                            <button type="button" class="btn btn-outline-primary" id="toggleResetPassword">
                                <i class="bi bi-key-fill me-1"></i> Đặt lại mật khẩu
                            </button>
                        </div>

                        <div class="d-none">
                            <input asp-for="DatLaiMatKhau" />
                        </div>

                        <div id="passwordPanel" class="password-panel @(Model.DatLaiMatKhau ? "show" : string.Empty)">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label asp-for="MatKhauMoi" class="form-label fw-semibold"></label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="bi bi-key-fill text-primary"></i></span>
                                        <input asp-for="MatKhauMoi" class="form-control" placeholder="Nhập mật khẩu mới" />
                                    </div>
                                    <span asp-validation-for="MatKhauMoi" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="XacNhanMatKhauMoi" class="form-label fw-semibold"></label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="bi bi-shield-lock-fill text-primary"></i></span>
                                        <input asp-for="XacNhanMatKhauMoi" class="form-control" placeholder="Nhập lại mật khẩu mới" />
                                    </div>
                                    <span asp-validation-for="XacNhanMatKhauMoi" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="action-row mt-4">
                        <a asp-action="Details" asp-route-id="@Model.IdAdmin" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-1"></i> Quay lại chi tiết
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check2-circle me-1"></i> Lưu thay đổi
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        const toggleButton = document.getElementById('toggleResetPassword');
        const checkbox = document.getElementById('DatLaiMatKhau');
        const panel = document.getElementById('passwordPanel');

        function syncPasswordPanel() {
            const shouldShow = checkbox.checked;
            panel.classList.toggle('show', shouldShow);
            toggleButton.classList.toggle('btn-primary', shouldShow);
            toggleButton.classList.toggle('btn-outline-primary', !shouldShow);
            toggleButton.innerHTML = shouldShow
                ? '<i class="bi bi-eye-slash-fill me-1"></i> Ẩn đặt lại mật khẩu'
                : '<i class="bi bi-key-fill me-1"></i> Đặt lại mật khẩu';
        }

        toggleButton.addEventListener('click', function () {
            checkbox.checked = !checkbox.checked;
            syncPasswordPanel();
        });

        syncPasswordPanel();
    </script>
}
