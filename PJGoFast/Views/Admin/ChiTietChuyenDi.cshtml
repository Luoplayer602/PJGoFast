@using PJGoFast.Models.Entities
@using PJGoFast.Models.Enums
@model ChuyenDi

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Chi tiết Chuyến đi";

    var statusText = Model.TrangThai switch
    {
        TrangThaiChuyen.CHO => "Đang xem báo giá",
        TrangThaiChuyen.MOI => "Chờ phân công",
        TrangThaiChuyen.DA_PHAN_CONG => "Đã phân công",
        TrangThaiChuyen.DA_NHAN => "Tài xế đã nhận",
        TrangThaiChuyen.DANG_DON => "Đang đón",
        TrangThaiChuyen.DA_DON => "Đã đón",
        TrangThaiChuyen.DANG_DI_CHUYEN => "Đang di chuyển",
        TrangThaiChuyen.HOAN_TAT => "Hoàn tất",
        TrangThaiChuyen.HUY => "Đã hủy",
        _ => Model.TrangThai.ToString()
    };
}

<style>
    .trip-detail-page {
        display: grid;
        grid-template-columns: minmax(0, 1.3fr) minmax(300px, .9fr);
        gap: 18px;
    }

    .trip-card {
        background: #fff;
        border-radius: 24px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 10px 28px rgba(15, 23, 42, .06);
        overflow: hidden;
    }

    .trip-hero {
        padding: 24px;
        color: #fff;
        background: linear-gradient(160deg, #0f172a, #ea580c 72%, #fb923c);
    }

    .trip-hero h1 {
        margin: 0 0 8px;
        font-size: 1.5rem;
        font-weight: 800;
    }

    .hero-chip {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 12px;
        border-radius: 999px;
        background: rgba(255, 255, 255, .14);
        border: 1px solid rgba(255, 255, 255, .18);
        font-size: .8rem;
        font-weight: 700;
        margin: 12px 8px 0 0;
    }

    .trip-body {
        padding: 22px 24px;
        display: grid;
        gap: 18px;
    }

    .info-block {
        background: #f8fbff;
        border: 1px solid #e2e8f0;
        border-radius: 20px;
        padding: 18px;
    }

    .info-block h2 {
        margin: 0 0 12px;
        font-size: .84rem;
        text-transform: uppercase;
        letter-spacing: .06em;
        color: #64748b;
        font-weight: 800;
    }

    .info-item + .info-item {
        margin-top: 10px;
    }

    .info-item small {
        display: block;
        color: #94a3b8;
        margin-bottom: 3px;
    }

    .info-item strong {
        display: block;
        line-height: 1.45;
        color: #0f172a;
    }

    .action-stack {
        display: grid;
        gap: 10px;
    }

    .action-stack .btn {
        border-radius: 16px;
        padding: 12px 16px;
        font-weight: 800;
    }

    .logs-container {
        max-height: 400px;
        overflow-y: auto;
    }

    .log-item {
        padding: 12px;
        border-left: 3px solid #2563eb;
        background: #eff6ff;
        border-radius: 8px;
        margin-bottom: 10px;
    }

    .log-item:last-child {
        margin-bottom: 0;
    }

    .log-time {
        font-size: .75rem;
        font-weight: 700;
        color: #2563eb;
        text-transform: uppercase;
        letter-spacing: .05em;
    }

    .log-text {
        margin: 4px 0 0;
        font-size: .9rem;
        color: #0f172a;
        line-height: 1.5;
    }

    @@media (max-width: 992px) {
        .trip-detail-page {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="trip-detail-page">
    <section class="trip-card">
        <div class="trip-hero">
            <h1>Chuyến @Model.IdChuyenDi.Substring(0, 8)...</h1>
            <div>Thông tin trạng thái, lộ trình và người phụ trách của chuyến đi.</div>
            <div>
                <span class="hero-chip"><i class="bi bi-flag"></i>@statusText</span>
                <span class="hero-chip"><i class="bi bi-clock"></i>@Model.ThoiGianDon.ToString("HH:mm dd/MM/yyyy")</span>
                <span class="hero-chip"><i class="bi bi-cash-stack"></i>@(Model.GiaTamTinh?.ToString("N0") ?? "0") đ</span>
            </div>
        </div>

        <div class="trip-body">
            <div class="info-block">
                <h2>Lộ trình</h2>
                <div class="info-item"><small>Điểm đón</small><strong>@Model.DiemDon</strong></div>
                <div class="info-item"><small>Điểm đến</small><strong>@Model.DiemDen</strong></div>
                <div class="info-item"><small>Loại xe yêu cầu</small><strong>@Model.LoaiXeYeuCau</strong></div>
                <div class="info-item"><small>Ghi chú</small><strong>@(string.IsNullOrWhiteSpace(Model.GhiChu) ? "Không có" : Model.GhiChu)</strong></div>
            </div>

            <div class="info-block">
                <h2>Người phụ trách</h2>
                <div class="info-item"><small>Khách hàng</small><strong>@(Model.KhachHang != null ? $"{Model.KhachHang.HoVaTen} · {Model.KhachHang.SDT}" : "Không xác định")</strong></div>
                <div class="info-item"><small>Tài xế</small><strong>@(Model.TaiXe != null ? $"{Model.TaiXe.HoVaTen} · {Model.TaiXe.SDT}" : "Chưa phân công")</strong></div>
                <div class="info-item"><small>Điều phối</small><strong>@(Model.Admin != null ? $"{Model.Admin.HoVaTen} · {Model.Admin.SDT}" : "Chưa phân công")</strong></div>
            </div>

            <div class="info-block">
                <h2>Thanh toán</h2>
                <div class="info-item"><small>Giá tạm tính</small><strong>@(Model.GiaTamTinh?.ToString("N0") ?? "0") đ</strong></div>
                <div class="info-item"><small>Giá thực tế</small><strong>@(Model.GiaThucTe?.ToString("N0") ?? "Chưa xác định") đ</strong></div>
                <div class="info-item"><small>Trạng thái thanh toán</small><strong>@(Model.ThanhToan != null ? "Đã thanh toán" : "Chưa thanh toán")</strong></div>
            </div>
        </div>
    </section>

    <section class="trip-card">
        <div class="trip-body">
            <div class="info-block">
                <h2>Nhật ký chuyến đi</h2>
                @if (Model.NhatKys != null && Model.NhatKys.Any())
                {
                    <div class="logs-container">
                        @foreach (var log in Model.NhatKys.OrderByDescending(x => x.ThoiGian))
                        {
                            <div class="log-item">
                                <div class="log-time">@log.ThoiGian.ToString("HH:mm:ss dd/MM/yyyy")</div>
                                <div class="log-text">@log.LogText</div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div style="color: #6b7280; text-align: center; padding: 20px 0;">
                        <i class="bi bi-inbox" style="font-size: 1.5rem; display: block; margin-bottom: 10px;"></i>
                        Chưa có nhật ký nào.
                    </div>
                }
            </div>

            <div class="action-stack">
                <a asp-action="QuanLyChuyenDi" class="btn btn-light border">
                    <i class="bi bi-arrow-left me-1"></i> Quay lại danh sách
                </a>
            </div>
        </div>
    </section>
</div>
